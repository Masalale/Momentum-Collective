---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Contact - Momentum Collective" description="Get in touch with Momentum Collective. Partner with us to build the future of Africa.">
    <section id="contact" class="contact-page">
        <div class="container">
            <h2 class="section-title">Get in <span class="highlight">Touch</span></h2>
            <p class="section-subtitle text-center">We'd love to hear from you. Reach out to us through any of the
                channels below.</p>

            <div class="contact-grid">
                <div class="contact-card">
                    <div class="contact-icon"><i class="fas fa-envelope"></i></div>
                    <h3 class="contact-title">Email Us</h3>
                    <p>For general inquiries, partnerships, or to hire our developers, please send us an email.</p>
                    <a href="mailto:management@eyev.africa" class="btn btn-primary">management@eyev.africa</a>
                </div>

                <div class="contact-card">
                    <div class="contact-icon"><i class="fas fa-phone"></i></div>
                    <h3 class="contact-title">Call Us</h3>
                    <p>For urgent matters or to speak with a member of our team directly, feel free to give us a
                        call.</p>
                    <a href="tel:+254110175110" class="btn btn-primary">+254 110 175 110</a>
                </div>
            </div>

            <div class="social-contact">
                <h3 class="text-center">Follow Our Journey</h3>
                <p class="text-center">Stay connected and see what we're building next.</p>
                <div class="social-links">

                    <a href="https://www.linkedin.com/company/momentumlabsclg/posts/?feedView=all"
                        class="social-link"><i class="fab fa-linkedin"></i></a>

                    <a href="https://www.instagram.com/momentumcollectiveclg?igsh=c3FzNGJzZjZjNmNt"
                        class="social-link"><i class="fab fa-instagram"></i></a>

                    <a href="https://github.com/ivycommunity" class="social-link"><i class="fab fa-github"></i></a>
                </div>
            </div>
        </div>
    </section>
</BaseLayout>
