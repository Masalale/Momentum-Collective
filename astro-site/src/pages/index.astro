---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Momentum Collective - Digital Solutions for a Connected Africa">
    <!-- Hero Section -->
    <section id="home" class="hero">
        <div class="container">
            <div class="hero-content">
                <div class="hero-badge">
                    <span class="badge-text">🚀 Pan-African Tech Powerhouse</span>
                </div>
                <h1 class="hero-title">
                    Building Africa's
                    <span class="highlight">Digital Future</span>
                    Together
                </h1>
                <p class="hero-subtitle">
                    We empower communities, preserve culture, and create scalable solutions that drive real change
                    across the continent.
                </p>
                <div class="hero-buttons">
                    <a href="/apps" class="btn btn-primary btn-large">
                        <i class="fas fa-rocket"></i>
                        Explore Our Solutions
                    </a>
                    <a href="/contact" class="btn btn-outline-light btn-large">
                        <i class="fas fa-handshake"></i>
                        Partner With Us
                    </a>
                </div>
            </div>
            <div class="hero-visual">
                <div class="hero-image-container">
                    <img src="/assets/momentum-labs2.jpeg"
                        alt="Abstract representation of Momentum Collective's digital innovation and African focus."
                        class="hero-main-image">
                    <div class="floating-elements">
                        <div class="floating-card card-1">
                            <i class="fas fa-mobile-alt"></i>
                            <span>Mobile Apps</span>
                        </div>
                        <div class="floating-card card-2">
                            <i class="fas fa-globe-africa"></i>
                            <span>Pan-African</span>
                        </div>
                        <div class="floating-card card-3">
                            <i class="fas fa-users"></i>
                            <span>Community</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="hero-bg-pattern"></div>
    </section>

    <!-- Core Values Section -->
    <section class="core-values">
        <div class="container">
            <div class="section-header">
                <h2 class="section-title">Our Core Values</h2>
                <p class="section-subtitle">The principles that drive our mission forward and shape everything we
                    build.</p>
            </div>
            <div class="values-grid">
                <div class="value-card">
                    <div class="value-icon">
                        <i class="fas fa-lightbulb"></i>
                    </div>
                    <h3 class="value-title">Innovation</h3>
                    <p class="value-description">We are driven by a relentless pursuit of innovation, constantly
                        exploring new technologies to create groundbreaking solutions that solve real African
                        challenges.</p>
                </div>
                <div class="value-card">
                    <div class="value-icon">
                        <i class="fas fa-users"></i>
                    </div>
                    <h3 class="value-title">Community</h3>
                    <p class="value-description">We believe in the power of community and are dedicated to
                        empowering African youth and fostering collaboration across borders and cultures.</p>
                </div>
                <div class="value-card">
                    <div class="value-icon">
                        <i class="fas fa-shield-alt"></i>
                    </div>
                    <h3 class="value-title">Integrity</h3>
                    <p class="value-description">We operate with unwavering integrity, ensuring transparency and
                        accountability in all our endeavors while honoring our cultural heritage.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- Impact Section -->
    <section class="impact">
        <div class="container">
            <div class="section-header">
                <h2 class="section-title">Our Impact</h2>
                <p class="section-subtitle">Real change through technology, measured in lives touched and
                    communities transformed.</p>
            </div>
            <div class="impact-grid">
                <div class="impact-card">
                    <div class="impact-icon">
                        <i class="fas fa-mobile-alt"></i>
                    </div>
                    <div class="impact-content">
                        <h3>Digital Accessibility</h3>
                        <p>Bringing essential services to rural communities through innovative mobile solutions.</p>
                    </div>
                </div>
                <div class="impact-card">
                    <div class="impact-icon">
                        <i class="fas fa-graduation-cap"></i>
                    </div>
                    <div class="impact-content">
                        <h3>Youth Empowerment</h3>
                        <p>Training and mentoring the next generation of African developers and entrepreneurs.</p>
                    </div>
                </div>
                <div class="impact-card">
                    <div class="impact-icon">
                        <i class="fas fa-globe-africa"></i>
                    </div>
                    <div class="impact-content">
                        <h3>Cultural Preservation</h3>
                        <p>Using technology to preserve and promote African languages, traditions, and heritage.</p>
                    </div>
                </div>
                <div class="impact-card">
                    <div class="impact-icon">
                        <i class="fas fa-handshake"></i>
                    </div>
                    <div class="impact-content">
                        <h3>Economic Growth</h3>
                        <p>Creating sustainable business opportunities and supporting local economies across Africa.
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- CTA Section -->
    <section class="cta">
        <div class="container">
            <div class="cta-content">
                <div class="cta-badge">
                    <span>🚀 Ready to Transform Your Vision?</span>
                </div>
                <h2>Let's Build Something Amazing Together</h2>
                <p>Whether you're a startup looking to disrupt, a business seeking digital transformation, or a
                    community organization with a mission, we're here to turn your ideas into reality.</p>
                <div class="cta-features">
                    <div class="cta-feature">
                        <i class="fas fa-check-circle"></i>
                        <span>Custom Solutions</span>
                    </div>
                    <div class="cta-feature">
                        <i class="fas fa-check-circle"></i>
                        <span>Expert Team</span>
                    </div>
                    <div class="cta-feature">
                        <i class="fas fa-check-circle"></i>
                        <span>Pan-African Focus</span>
                    </div>
                </div>
                <div class="cta-buttons">
                    <a href="/contact" class="btn btn-primary btn-cta">
                        <i class="fas fa-paper-plane"></i>
                        Start Your Project
                    </a>
                    <a href="/services" class="btn btn-outline-light btn-cta">
                        <i class="fas fa-info-circle"></i>
                        Learn More
                    </a>
                    <a href="/apps" class="btn btn-secondary btn-cta">
                        <i class="fas fa-eye"></i>
                        View Our Work
                    </a>
                </div>
            </div>
            <div class="cta-visual">
                <div class="cta-shape shape-1"></div>
                <div class="cta-shape shape-2"></div>
                <div class="cta-shape shape-3"></div>
            </div>
        </div>
    </section>
</BaseLayout>
