---
interface Props {
    title: string;
    description?: string;
}

const { title, description = "Pan-African, scalable digital solutions. We build, innovate, and empower through Momentum Labs and Momentum Foundation." } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{title}</title>
    <meta name="description" content={description}>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/styles.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <meta name="theme-color" content="#8b5cf6">
    <meta property="og:title" content={title}>
    <meta property="og:description" content={description}>
    <meta property="og:image" content="/assets/momentum-og-image.png">
    <meta property="og:url" content="https://momentum.eyev.africa">
    <meta name="twitter:card" content="summary_large_image">
</head>
<body>
    <!-- Navigation -->
    <nav class="navbar">
        <div class="container">
            <div class="nav-brand">
                <span class="brand-name">Momentum Collective</span>
            </div>
            <div class="nav-menu" id="nav-menu">
                <ul class="nav-links">
                    <li><a href="/" class="nav-link">Home</a></li>
                    <li><a href="/about" class="nav-link">About</a></li>
                    <li><a href="/apps" class="nav-link">Apps</a></li>
                    <li><a href="/services" class="nav-link">Services</a></li>
                    <li><a href="/contact" class="nav-link">Contact</a></li>
                </ul>
            </div>
            <div class="nav-toggle" id="nav-toggle">
                <i class="fas fa-bars"></i>
            </div>
        </div>
    </nav>

    <main>
        <slot />
    </main>

    <!-- Footer -->
    <footer class="footer">
        <div class="container">
            <div class="footer-content">
                <p class="footer-copyright">&copy; 2025 Momentum Collective. All rights reserved.</p>
                <div class="social-links">
                    <a href="https://www.linkedin.com/company/momentumlabsclg/posts/?feedView=all" class="social-link">
                        <i class="fab fa-linkedin"></i>
                    </a>
                    <a href="https://www.instagram.com/momentumcollectiveclg?igsh=c3FzNGJzZjZjNmNt" class="social-link">
                        <i class="fab fa-instagram"></i>
                    </a>
                    <a href="https://github.com/ivycommunity" class="social-link">
                        <i class="fab fa-github"></i>
                    </a>
                </div>
            </div>
        </div>
    </footer>

    <script is:inline src="/script.js"></script>
</body>
</html>
