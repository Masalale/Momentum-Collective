---
interface Props {
  title: string;
  description?: string;
  barbaNamespace: string;
}

import "../styles/global.css";
import "../styles/fixes.css";
import { SITE_URL } from "../lib/constants";

const {
  title,
  description = "Momentum Labs CLG - Africa's execution-first product lab. Build. Ship. Sell. Scale.",
  barbaNamespace,
} = Astro.props;

const canonicalUrl = new URL(Astro.url.pathname, SITE_URL).toString();
const ogImageUrl = new URL('/assets/momentum-foundation.png', SITE_URL).toString();
const isNotFoundPage = barbaNamespace === 'not-found';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | Momentum Collective</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#FFFFFF" />
    <link rel="icon" type="image/png" href="/assets/momentum-labs.png" />
    <link rel="canonical" href={canonicalUrl} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="preload"
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,300;0,400;0,500;1,300;1,400&family=IBM+Plex+Sans:wght@300;400;500;600&family=IBM+Plex+Mono:wght@400;500&display=swap"
      as="style"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,300;0,400;0,500;1,300;1,400&family=IBM+Plex+Sans:wght@300;400;500;600&family=IBM+Plex+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />

    <meta property="og:title" content={`${title} | Momentum Collective`} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Momentum Collective" />
    <meta
      property="og:image"
      content={ogImageUrl}
    />
    <meta property="og:image:width" content="500" />
    <meta property="og:image:height" content="500" />
    <meta name="twitter:card" content="summary" />
    <meta
      name="twitter:image"
      content={ogImageUrl}
    />
  </head>
  <body class={isNotFoundPage ? 'is-not-found' : undefined}>
    <nav class="main-nav" id="main-nav">
      <div class="nav-container">
        <a href="/" class="nav-logo">Momentum Collective</a>

        <div class="nav-links">
          <a href="/about" class="nav-link">About</a>
          <a href="/apps" class="nav-link">Apps</a>
          <a href="/services" class="nav-link">Services</a>
          <a href="/courses" class="nav-link">Courses</a>
          <a href="/partners" class="nav-link">Partners</a>
          <a href="/newsletter" class="nav-link"            >Newsletter</a
          >
          <a href="/contact" class="nav-link">Contact</a>
        </div>

        <button class="nav-toggle" id="nav-toggle" aria-label="Toggle menu">
          <span class="nav-toggle-bar" aria-hidden="true"></span>
        </button>
      </div>
    </nav>

    <div class="mobile-menu" id="mobile-menu">
      <a href="/about" class="nav-link">About</a>
      <a href="/apps" class="nav-link">Apps</a>
      <a href="/services" class="nav-link">Services</a>
      <a href="/courses" class="nav-link">Courses</a>
      <a href="/partners" class="nav-link">Partners</a>
      <a href="/newsletter" class="nav-link"        >Newsletter</a
      >
      <a href="/contact" class="nav-link">Contact</a>
    </div>

    <div data-barba="wrapper" class={isNotFoundPage ? 'layout-fill' : undefined}>
      <main data-barba="container" data-barba-namespace={barbaNamespace} class={isNotFoundPage ? 'layout-fill' : undefined}>
        <slot />
      </main>
    </div>

    <footer class="main-footer">
      <div class="container">
        <div class="footer-content">
          <p class="footer-tagline">Build. Ship. Sell. Scale.</p>

          <div class="footer-social">
            <a
              href="https://www.linkedin.com/company/momentumlabsclg/"
              target="_blank"
              rel="noopener noreferrer"
              class="social-link"
              aria-label="LinkedIn"
            >
              <i data-lucide="linkedin"></i>
            </a>
            <a
              href="https://www.instagram.com/momentumcollectiveclg"
              target="_blank"
              rel="noopener noreferrer"
              class="social-link"
              aria-label="Instagram"
            >
              <i data-lucide="instagram"></i>
            </a>
            <a
              href="https://github.com/ivycommunity"
              target="_blank"
              rel="noopener noreferrer"
              class="social-link"
              aria-label="GitHub"
            >
              <i data-lucide="github"></i>
            </a>
          </div>

          <p class="footer-copyright">
            © {new Date().getFullYear()} Momentum Collective. All rights reserved.
          </p>
        </div>
      </div>
    </footer>

    <div id="transition-overlay" aria-hidden="true"></div>

    <script>
      import { createIcons, ALL_ICONS } from "../scripts/icons";
      createIcons({ icons: ALL_ICONS });

      const navToggle = document.getElementById("nav-toggle");
      const mobileMenu = document.getElementById("mobile-menu");
      let isMenuOpen = false;

      if (navToggle && mobileMenu) {
        navToggle.addEventListener("click", () => {
          isMenuOpen = !isMenuOpen;
          mobileMenu.classList.toggle("open", isMenuOpen);
          navToggle.classList.toggle("is-open", isMenuOpen);
          navToggle.setAttribute(
            "aria-label",
            isMenuOpen ? "Close menu" : "Open menu",
          );
        });

        mobileMenu.querySelectorAll(".nav-link").forEach((link) => {
          link.addEventListener("click", () => {
            isMenuOpen = false;
            mobileMenu.classList.remove("open");
            navToggle.classList.remove("is-open");
            navToggle.setAttribute("aria-label", "Open menu");
          });
        });
      }
    </script>

    {
      !isNotFoundPage && (
        <script>
          import "../scripts/scroll-init";
          import "../scripts/page-transitions";
        </script>
      )
    }
  </body>
</html>
