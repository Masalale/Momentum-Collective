---
interface Props {
  title: string;
  description?: string;
  barbaNamespace: string;
}

import "../styles/global.css";
import "../styles/fixes.css";

const {
  title,
  description = "Momentum Labs CLG - Africa's execution-first product lab. Build. Ship. Sell. Scale.",
  barbaNamespace,
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | Momentum Collective</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#FFFFFF" />
    <link rel="icon" type="image/png" href="/assets/momentum-labs.png" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="preload"
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,300;0,400;0,500;1,300;1,400&family=IBM+Plex+Sans:wght@300;400;500;600&family=IBM+Plex+Mono:wght@400;500&display=swap"
      as="style"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,300;0,400;0,500;1,300;1,400&family=IBM+Plex+Sans:wght@300;400;500;600&family=IBM+Plex+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />

    <meta property="og:title" content={`${title} | Momentum Collective`} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Momentum Collective" />
    <meta
      property="og:image"
      content="https://momentum-collective.vercel.app/assets/momentum-foundation.png"
    />
    <meta property="og:image:width" content="500" />
    <meta property="og:image:height" content="500" />
    <meta name="twitter:card" content="summary" />
    <meta
      name="twitter:image"
      content="https://momentum-collective.vercel.app/assets/momentum-foundation.png"
    />
  </head>
  <body>
    <nav class="main-nav" id="main-nav">
      <div class="nav-container">
        <a href="/" class="nav-logo">Momentum Collective</a>

        <div class="nav-links">
          <a href="/" class="nav-link" data-page="home">Home</a>
          <a href="/about" class="nav-link" data-page="about">About</a>
          <a href="/apps" class="nav-link" data-page="apps">Apps</a>
          <a href="/services" class="nav-link" data-page="services">Services</a>
          <a href="/partners" class="nav-link" data-page="partners">Partners</a>
          <a href="/newsletter" class="nav-link" data-page="newsletter"
            >Newsletter</a
          >
          <a href="/contact" class="nav-link" data-page="contact">Contact</a>
        </div>

        <button class="nav-toggle" id="nav-toggle" aria-label="Toggle menu">
          <span class="nav-toggle-bar" aria-hidden="true"></span>
        </button>
      </div>
    </nav>

    <div class="mobile-menu" id="mobile-menu">
      <a href="/" class="nav-link" data-page="home">Home</a>
      <a href="/about" class="nav-link" data-page="about">About</a>
      <a href="/apps" class="nav-link" data-page="apps">Apps</a>
      <a href="/services" class="nav-link" data-page="services">Services</a>
      <a href="/partners" class="nav-link" data-page="partners">Partners</a>
      <a href="/newsletter" class="nav-link" data-page="newsletter"
        >Newsletter</a
      >
      <a href="/contact" class="nav-link" data-page="contact">Contact</a>
    </div>

    <div data-barba="wrapper">
      <main data-barba="container" data-barba-namespace={barbaNamespace}>
        <slot />
      </main>
    </div>

    <footer class="main-footer">
      <div class="container">
        <div class="footer-content">
          <p class="footer-tagline">Build. Ship. Sell. Scale.</p>

          <div class="footer-social">
            <a
              href="https://www.linkedin.com/company/momentumlabsclg/"
              target="_blank"
              rel="noopener noreferrer"
              class="social-link"
              aria-label="LinkedIn"
            >
              <i data-lucide="linkedin"></i>
            </a>
            <a
              href="https://www.instagram.com/momentumcollectiveclg"
              target="_blank"
              rel="noopener noreferrer"
              class="social-link"
              aria-label="Instagram"
            >
              <i data-lucide="instagram"></i>
            </a>
            <a
              href="https://github.com/ivycommunity"
              target="_blank"
              rel="noopener noreferrer"
              class="social-link"
              aria-label="GitHub"
            >
              <i data-lucide="github"></i>
            </a>
          </div>

          <p class="footer-copyright">
            © {new Date().getFullYear()} Momentum Collective. All rights reserved.
          </p>
        </div>
      </div>
    </footer>

    <div id="transition-overlay" aria-hidden="true"></div>

    <script>
      import {
        createIcons,
        Menu,
        X,
        // eslint-disable-next-line deprecation/deprecation
        Linkedin, Instagram, Github,
        ArrowRight,
        Zap,
        Users,
        Shield,
        Globe,
        CheckCircle,
        Smartphone,
        GraduationCap,
        Heart,
        DollarSign,
        Headphones,
        Scale,
        Mail,
        Phone,
        ChevronDown,
        Eye,
        Target,
        UserPlus,
        Languages,
        ShoppingBasket,
        Gamepad2,
        QrCode,
        CalendarCheck,
        Home,
        Package,
        BookOpen,
        Car,
        Shirt,
        Search,
        Layers,
        Rocket,
        Cloud,
        Code2,
        MapPin,
        Activity,
        Building2,
        CreditCard,
        Lock,
        MessageSquare,
        ShieldCheck,
        BarChart2,
        Megaphone,
        Filter,
        ScanLine,
        HardHat,
        Bot,
        Sprout,
        MapPinPlus,
        Pill,
        Baby,
        Stethoscope,
        Fingerprint,
        MessageCircle,
        BrainCircuit,
        TabletSmartphone,
        BadgeCheck,
        Droplets,
        Ambulance,
        CloudRain,
        HeartHandshake,
        Siren,
        Bell,
        Satellite,
        ShieldAlert,
        AlertCircle,
        Calendar,
        Timer,
        CheckCircle2,
        Handshake,
        ArrowUpRight,
        ExternalLink,
      } from "lucide";

      createIcons({
        icons: {
          Menu,
          X,
          Linkedin,
          Instagram,
          Github,
          ArrowRight,
          Zap,
          Users,
          Shield,
          Globe,
          CheckCircle,
          Smartphone,
          GraduationCap,
          Heart,
          DollarSign,
          Headphones,
          Scale,
          Mail,
          Phone,
          ChevronDown,
          Eye,
          Target,
          UserPlus,
          Languages,
          ShoppingBasket,
          Gamepad2,
          QrCode,
          CalendarCheck,
          Home,
          Package,
          BookOpen,
          Car,
          Shirt,
          Search,
          Layers,
          Rocket,
          Cloud,
          Code2,
          MapPin,
          Activity,
          Building2,
          CreditCard,
          Lock,
          MessageSquare,
          ShieldCheck,
          BarChart2,
          Megaphone,
          Filter,
          ScanLine,
          HardHat,
          Bot,
          Sprout,
          MapPinPlus,
          Pill,
          Baby,
          Stethoscope,
          Fingerprint,
          MessageCircle,
          BrainCircuit,
          TabletSmartphone,
          BadgeCheck,
          Droplets,
          Ambulance,
          CloudRain,
          HeartHandshake,
          Siren,
          Bell,
          Satellite,
          ShieldAlert,
          AlertCircle,
          Calendar,
          Timer,
          CheckCircle2,
          Handshake,
          ArrowUpRight,
          ExternalLink,
        },
      });

      const navToggle = document.getElementById("nav-toggle");
      const mobileMenu = document.getElementById("mobile-menu");
      let isMenuOpen = false;

      if (navToggle && mobileMenu) {
        navToggle.addEventListener("click", () => {
          isMenuOpen = !isMenuOpen;
          mobileMenu.classList.toggle("open", isMenuOpen);
          navToggle.classList.toggle("is-open", isMenuOpen);
          navToggle.setAttribute(
            "aria-label",
            isMenuOpen ? "Close menu" : "Open menu",
          );
        });

        mobileMenu.querySelectorAll(".nav-link").forEach((link) => {
          link.addEventListener("click", () => {
            isMenuOpen = false;
            mobileMenu.classList.remove("open");
            navToggle.classList.remove("is-open");
            navToggle.setAttribute("aria-label", "Open menu");
          });
        });
      }
    </script>

    <script>
      import "../scripts/scroll-init";
      import "../scripts/page-transitions";
    </script>
  </body>
</html>
