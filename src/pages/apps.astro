---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Portfolio"
  description="44+ live software systems built and sold by Momentum Labs CLG across 7 domains: AI, Blockchain & FinTech, Business Suite, Social Impact, Commerce, Games, and Corporate Websites — serving African markets."
  barbaNamespace="apps"
>
  <!-- 1. PAGE HERO -->
  <section class="hero">
    <div class="container">
      <div class="hero-content">
        <p class="hero-eyebrow">Live Software Portfolio</p>
        <h1 class="hero-title display-3xl">44+ Systems in the Market</h1>
        <p
          class="hero-subtext"
          style="font-size: var(--text-base); margin: 0 auto; max-width: 600px;"
        >
          Cohort-built platforms, AI tools, and hackathon projects across 7
          domains — all actively maintained and deployed into African markets.
        </p>
      </div>
    </div>
  </section>

  <!-- 2. MARQUEE -->
  <div class="marquee">
    <div class="marquee-track">
      <div class="marquee-content">
        <span>AI & Intelligent Systems</span><span class="marquee-dot"></span>
        <span>Blockchain & FinTech</span><span class="marquee-dot"></span>
        <span>Business Suite</span><span class="marquee-dot"></span>
        <span>Social Impact</span><span class="marquee-dot"></span>
        <span>Commerce Tools & Marketplaces</span><span class="marquee-dot"></span>
        <span>Games</span><span class="marquee-dot"></span>
        <span>Websites Built for Companies</span><span class="marquee-dot"></span>
        <span>AI & Intelligent Systems</span><span class="marquee-dot"></span>
        <span>Blockchain & FinTech</span><span class="marquee-dot"></span>
        <span>Business Suite</span><span class="marquee-dot"></span>
        <span>Social Impact</span><span class="marquee-dot"></span>
        <span>Commerce Tools & Marketplaces</span><span class="marquee-dot"></span>
        <span>Games</span><span class="marquee-dot"></span>
        <span>Websites Built for Companies</span><span class="marquee-dot"></span>
        <span>Built by African Youth</span>
      </div>
      <div class="marquee-content" aria-hidden="true">
        <span>AI & Intelligent Systems</span><span class="marquee-dot"></span>
        <span>Blockchain & FinTech</span><span class="marquee-dot"></span>
        <span>Business Suite</span><span class="marquee-dot"></span>
        <span>Social Impact</span><span class="marquee-dot"></span>
        <span>Commerce Tools & Marketplaces</span><span class="marquee-dot"></span>
        <span>Games</span><span class="marquee-dot"></span>
        <span>Websites Built for Companies</span><span class="marquee-dot"></span>
        <span>AI & Intelligent Systems</span><span class="marquee-dot"></span>
        <span>Blockchain & FinTech</span><span class="marquee-dot"></span>
        <span>Business Suite</span><span class="marquee-dot"></span>
        <span>Social Impact</span><span class="marquee-dot"></span>
        <span>Commerce Tools & Marketplaces</span><span class="marquee-dot"></span>
        <span>Games</span><span class="marquee-dot"></span>
        <span>Websites Built for Companies</span><span class="marquee-dot"></span>
        <span>Built by African Youth</span>
      </div>
    </div>
  </div>

  <!-- 3. AI & INTELLIGENT SYSTEMS -->
  <section class="section">
    <div class="container">
      <div class="section-header">
        <p class="eyebrow">AI & Intelligent Systems</p>
        <h2 class="section-title">AI-Forward, Africa-Focused</h2>
        <p class="section-description">
          Embedding intelligence across healthcare, agriculture, education,
          marketing, and governance — built for African realities.
        </p>
      </div>

      <div class="card-grid-editorial cols-3">
        <div class="card-editorial">
          <div class="card-editorial-icon">
            <i data-lucide="message-square"></i>
          </div>
          <h3 class="card-editorial-title">AI Chatbot</h3>
          <p class="card-editorial-description">
            24/7 AI-powered automated customer support system deployable across
            businesses and institutions.
          </p>
        </div>

        <div class="card-editorial">
          <div class="card-editorial-icon">
            <i data-lucide="shield-check"></i>
          </div>
          <h3 class="card-editorial-title">Misinformation Analysis AI</h3>
          <p class="card-editorial-description">
            AI credibility analysis tool that scores text and screenshots for
            misinformation risk.
          </p>
        </div>

        <div class="card-editorial">
          <div class="card-editorial-icon"><i data-lucide="globe"></i></div>
          <h3 class="card-editorial-title">Multilingual Translation AI</h3>
          <p class="card-editorial-description">
            Multilingual conversational AI platform with real-time translation
            bridging language gaps across Africa.
          </p>
        </div>

        <div class="card-editorial">
          <div class="card-editorial-icon">
            <i data-lucide="bar-chart-2"></i>
          </div>
          <h3 class="card-editorial-title">Social Intelligence CRM</h3>
          <p class="card-editorial-description">
            AI-powered social CRM integrating Instagram, WhatsApp, and digital
            communication channels into a unified intelligence layer.
          </p>
        </div>

        <div class="card-editorial">
          <div class="card-editorial-icon"><i data-lucide="megaphone"></i></div>
          <h3 class="card-editorial-title">AI Marketing Automation</h3>
          <p class="card-editorial-description">
            SME marketing automation system for WhatsApp and SMS campaigns —
            reach more customers with less effort.
          </p>
        </div>

        <div class="card-editorial">
          <div class="card-editorial-icon"><i data-lucide="filter"></i></div>
          <h3 class="card-editorial-title">Toxic Content Moderator</h3>
          <p class="card-editorial-description">
            AI moderation system that detects harmful content and suggests
            constructive rewrites for safer digital spaces.
          </p>
        </div>

        <div class="card-editorial">
          <div class="card-editorial-icon"><i data-lucide="scan-line"></i></div>
          <h3 class="card-editorial-title">AI Disprover</h3>
          <p class="card-editorial-description">
            Browser extension that detects AI-generated content in real time,
            preserving information integrity.
          </p>
        </div>

        <div class="card-editorial">
          <div class="card-editorial-icon"><i data-lucide="sprout"></i></div>
          <h3 class="card-editorial-title">Agricultural Intelligence Index</h3>
          <p class="card-editorial-description">
            Climate-smart agricultural intelligence platform helping farmers
            optimise crop production and market decisions using climate data,
            soil insights, and logistics analysis.
          </p>
        </div>

        <div class="card-editorial">
          <div class="card-editorial-icon">
            <i data-lucide="message-circle"></i>
          </div>
          <h3 class="card-editorial-title">SMS Tutoring AI</h3>
          <p class="card-editorial-description">
            AI-powered tutoring system delivered through SMS, enabling displaced
            students to learn using basic mobile phones with adaptive quizzes
            and personalised feedback.
          </p>
        </div>

        <div class="card-editorial">
          <div class="card-editorial-icon">
            <i data-lucide="brain-circuit"></i>
          </div>
          <h3 class="card-editorial-title">Offline Learning AI</h3>
          <p class="card-editorial-description">
            AI-powered learning platform for displaced students with AI tutor
            avatars, interactive modules, and virtual STEM labs — all optimised
            for low-bandwidth environments.
          </p>
        </div>

        <div class="card-editorial">
          <div class="card-editorial-icon">
            <i data-lucide="stethoscope"></i>
          </div>
          <h3 class="card-editorial-title">Healthcare Compliance Audit</h3>
          <p class="card-editorial-description">
            Digital medical compliance auditing platform converting government
            healthcare protocols into computable rules and verifying hospital
            practices with AI-assisted analysis.
          </p>
        </div>

        <div class="card-editorial">
          <div class="card-editorial-icon">
            <i data-lucide="tablet-smartphone"></i>
          </div>
          <h3 class="card-editorial-title">Frontline Health AI</h3>
          <p class="card-editorial-description">
            Clinical AI workflow for CHPs and refugee caregivers. Features
            on-device symptom analysis, low-bandwidth video triage, and QR-based
            patient records to scale specialist reach.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- 4. BLOCKCHAIN & FINTECH -->
  <section class="section section-alt">
    <div class="container">
      <div class="section-header">
        <p class="eyebrow">Blockchain & FinTech</p>
        <h2 class="section-title">Built for the African Economy</h2>
        <p class="section-description">
          Secure, transparent financial infrastructure and identity systems
          designed for the realities of African markets.
        </p>
      </div>

      <div class="card-grid-editorial cols-3">
        <div class="card-editorial">
          <div class="card-editorial-icon"><i data-lucide="lock"></i></div>
          <h3 class="card-editorial-title">Blockchain Banking</h3>
          <p class="card-editorial-description">
            Secure cross-branch banking infrastructure with immutable audit
            trails, permissioned access, and full transaction transparency.
          </p>
        </div>

        <div class="card-editorial">
          <div class="card-editorial-icon">
            <i data-lucide="credit-card"></i>
          </div>
          <h3 class="card-editorial-title">Debt Collection System</h3>
          <p class="card-editorial-description">
            Digital debt management solution designed for SACCOs, micro-lenders,
            and financial institutions.
          </p>
        </div>

        <div class="card-editorial">
          <div class="card-editorial-icon">
            <i data-lucide="badge-check"></i>
          </div>
          <h3 class="card-editorial-title">Credential Verification Hub</h3>
          <p class="card-editorial-description">
            Blockchain-based credential verification and scholarship
            transparency platform — institutions issue tamper-proof digital
            certificates while donors track fund distribution.
          </p>
        </div>

        <div class="card-editorial">
          <div class="card-editorial-icon">
            <i data-lucide="fingerprint"></i>
          </div>
          <h3 class="card-editorial-title">Refugee Identity Platform</h3>
          <p class="card-editorial-description">
            Digital identity and aid access platform for refugees —
            blockchain-verified profiles, secure document storage, and NGO
            interaction via chatbot and USSD.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- 5. BUSINESS SUITE -->
  <section class="section">
    <div class="container">
      <div class="section-header">
        <p class="eyebrow">Business Suite</p>
        <h2 class="section-title">SaaS for Growing Businesses</h2>
        <p class="section-description">
          Practical operations tools addressing real inefficiencies across
          African SMEs, enterprises, and institutions.
        </p>
      </div>

      <div class="card-grid-editorial cols-3">
        <div class="card-editorial">
          <div class="card-editorial-icon"><i data-lucide="activity"></i></div>
          <h3 class="card-editorial-title">Hospital Operations System</h3>
          <p class="card-editorial-description">
            Digital hospital management system streamlining patient flow,
            medical records, staff coordination, and operational reporting.
          </p>
        </div>

        <div class="card-editorial">
          <div class="card-editorial-icon"><i data-lucide="package"></i></div>
          <h3 class="card-editorial-title">Inventory System</h3>
          <p class="card-editorial-description">
            Smart stock management for SMEs with forecasting and intelligent
            restock insights.
          </p>
        </div>

        <div class="card-editorial">
          <div class="card-editorial-icon">
            <i data-lucide="calendar-check"></i>
          </div>
          <h3 class="card-editorial-title">Booking System</h3>
          <p class="card-editorial-description">
            Appointment scheduling and client management platform for service
            providers.
          </p>
        </div>

        <div class="card-editorial">
          <div class="card-editorial-icon"><i data-lucide="home"></i></div>
          <h3 class="card-editorial-title">Property & Tenant Management</h3>
          <p class="card-editorial-description">
            Property and tenant management system with WhatsApp integration,
            automated rent tracking, and landlord-tenant communication tools.
          </p>
        </div>

        <div class="card-editorial">
          <div class="card-editorial-icon"><i data-lucide="hard-hat"></i></div>
          <h3 class="card-editorial-title">Construction Manager</h3>
          <p class="card-editorial-description">
            Platform for construction managers to monitor site operations, track
            materials, manage budgets, and assign tasks in real time.
          </p>
        </div>

        <div class="card-editorial">
          <div class="card-editorial-icon"><i data-lucide="users"></i></div>
          <h3 class="card-editorial-title">Workforce Management Platform</h3>
          <p class="card-editorial-description">
            Workforce management platform handling employee records, attendance,
            and payroll support.
          </p>
        </div>

        <div class="card-editorial">
          <div class="card-editorial-icon"><i data-lucide="book-open"></i></div>
          <h3 class="card-editorial-title">Learning Management System</h3>
          <p class="card-editorial-description">
            Digital learning platform for schools, institutions, and training
            programs — accessible, robust, and built for African connectivity.
          </p>
        </div>

        <div class="card-editorial">
          <div class="card-editorial-icon"><i data-lucide="qr-code"></i></div>
          <h3 class="card-editorial-title">M-Pesa QR Payment System</h3>
          <p class="card-editorial-description">
            Fast, secure, cashless payment solution for businesses and
            merchants.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- 6. SOCIAL IMPACT -->
  <section class="section section-alt">
    <div class="container">
      <div class="section-header">
        <p class="eyebrow">Social Impact</p>
        <h2 class="section-title">Built for Impact at Scale</h2>
        <p class="section-description">
          Digital systems addressing healthcare, crisis response, safety,
          education, and cultural preservation across underserved communities.
        </p>
      </div>

      <div class="card-grid-editorial cols-3">
        <div class="card-editorial">
          <div class="card-editorial-icon"><i data-lucide="shield"></i></div>
          <h3 class="card-editorial-title">Immunization Tracker</h3>
          <p class="card-editorial-description">
            Digital health and immunization management platform enabling
            vaccination tracking, structured reporting, and clinic coordination.
          </p>
        </div>

        <div class="card-editorial">
          <div class="card-editorial-icon"><i data-lucide="baby"></i></div>
          <h3 class="card-editorial-title">Maternal Health Monitoring</h3>
          <p class="card-editorial-description">
            Maternal health monitoring platform detecting high-risk pregnancies
            early, improving communication between expectant mothers and rural
            healthcare providers.
          </p>
        </div>

        <div class="card-editorial">
          <div class="card-editorial-icon">
            <i data-lucide="heart-pulse"></i>
          </div>
          <h3 class="card-editorial-title">
            Pregnancy Wellness & Early Detection
          </h3>
          <p class="card-editorial-description">
            Early risk detection and nutrition support for mothers in rural
            areas. Features daily health checkups, smart complication alerts,
            and fast hospital routing.
          </p>
        </div>

        <div class="card-editorial">
          <div class="card-editorial-icon">
            <i data-lucide="map-pin-plus"></i>
          </div>
          <h3 class="card-editorial-title">Healthcare Navigation</h3>
          <p class="card-editorial-description">
            Geospatial healthcare navigation platform helping Nairobi residents
            locate verified clinics, pharmacies, and emergency services —
            optimised for low-bandwidth environments.
          </p>
        </div>

        <div class="card-editorial">
          <div class="card-editorial-icon"><i data-lucide="pill"></i></div>
          <h3 class="card-editorial-title">Medicine Availability Index</h3>
          <p class="card-editorial-description">
            Healthcare availability dashboard letting clinics update medicine
            stock in real time while patients view availability on an
            interactive map.
          </p>
        </div>

        <div class="card-editorial">
          <div class="card-editorial-icon"><i data-lucide="ambulance"></i></div>
          <h3 class="card-editorial-title">Emergency Medical Dispatch</h3>
          <p class="card-editorial-description">
            Offline-first USSD medical dispatch system connecting emergencies
            with nearby boda boda riders for rapid hospital transport without
            internet access.
          </p>
        </div>

        <div class="card-editorial">
          <div class="card-editorial-icon">
            <i data-lucide="cloud-rain"></i>
          </div>
          <h3 class="card-editorial-title">Flood Crisis Response</h3>
          <p class="card-editorial-description">
            Flood crisis response platform enabling citizen incident reporting
            via web, SMS, or USSD while coordinators manage response through a
            real-time geospatial dashboard.
          </p>
        </div>

        <div class="card-editorial">
          <div class="card-editorial-icon"><i data-lucide="map-pin"></i></div>
          <h3 class="card-editorial-title">Crisis Coordination Portal</h3>
          <p class="card-editorial-description">
            Crisis coordination platform converting community reports into
            structured emergency response actions with geospatial mapping and
            responder routing.
          </p>
        </div>

        <div class="card-editorial">
          <div class="card-editorial-icon">
            <i data-lucide="heart-handshake"></i>
          </div>
          <h3 class="card-editorial-title">Humanitarian Aid Connector</h3>
          <p class="card-editorial-description">
            Centralised platform connecting individuals in crisis with nearby
            shelters, medical facilities, and volunteers.
          </p>
        </div>

        <div class="card-editorial">
          <div class="card-editorial-icon"><i data-lucide="siren"></i></div>
          <h3 class="card-editorial-title">Rapid Incident Response</h3>
          <p class="card-editorial-description">
            Next-generation emergency response platform for instant help
            requests during medical emergencies, fires, accidents, and security
            threats — works even when infrastructure fails.
          </p>
        </div>

        <div class="card-editorial">
          <div class="card-editorial-icon"><i data-lucide="bell"></i></div>
          <h3 class="card-editorial-title">Crisis Awareness Map</h3>
          <p class="card-editorial-description">
            Community-driven crisis awareness platform for incident reporting,
            safety alerts, and verified emergency information with real-time
            safety maps.
          </p>
        </div>

        <div class="card-editorial">
          <div class="card-editorial-icon"><i data-lucide="satellite"></i></div>
          <h3 class="card-editorial-title">Disaster Early Warning</h3>
          <p class="card-editorial-description">
            Satellite-powered disaster early warning system combining Earth
            observation data, weather models, and USSD alerts to warn
            communities before floods strike.
          </p>
        </div>

        <div class="card-editorial">
          <div class="card-editorial-icon">
            <i data-lucide="shield-alert"></i>
          </div>
          <h3 class="card-editorial-title">Personal Safety Wearable</h3>
          <p class="card-editorial-description">
            IoT wearable safety system for women and children that detects
            distress and automatically sends alerts, GPS location, and emergency
            notifications.
          </p>
        </div>

        <div class="card-editorial">
          <div class="card-editorial-icon"><i data-lucide="droplets"></i></div>
          <h3 class="card-editorial-title">Water Supply Management</h3>
          <p class="card-editorial-description">
            Community water access platform letting residents track supply
            schedules, report shortages, and receive availability alerts in real
            time.
          </p>
        </div>

        <div class="card-editorial">
          <div class="card-editorial-icon">
            <i data-lucide="tablet-smartphone"></i>
          </div>
          <h3 class="card-editorial-title">Education Access System</h3>
          <p class="card-editorial-description">
            Offline-first education platform providing mobile learning apps, SMS
            lessons, and USSD assessments with AI-driven adaptive quizzes for
            humanitarian contexts.
          </p>
        </div>

        <div class="card-editorial">
          <div class="card-editorial-icon"><i data-lucide="languages"></i></div>
          <h3 class="card-editorial-title">Native Language Learning</h3>
          <p class="card-editorial-description">
            Language-learning platform focused on preserving and teaching
            African dialects across generations.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- 7. COMMERCE TOOLS & MARKETPLACES -->
  <section class="section">
    <div class="container">
      <div class="section-header">
        <p class="eyebrow">Commerce Tools & Marketplaces</p>
        <h2 class="section-title">Commerce Infrastructure for Africa</h2>
        <p class="section-description">
          Marketplace and commerce platforms built for the realities of African
          trade — from fashion to agriculture to local vendors.
        </p>
      </div>

      <div class="card-grid-editorial cols-3">
        <div class="card-editorial">
          <div class="card-editorial-icon"><i data-lucide="shirt"></i></div>
          <h3 class="card-editorial-title">Fashion Commerce AI</h3>
          <p class="card-editorial-description">
            Smart fashion commerce platform featuring intelligent sizing
            technology for accurate fit recommendations.
          </p>
        </div>

        <div class="card-editorial">
          <div class="card-editorial-icon"><i data-lucide="car"></i></div>
          <h3 class="card-editorial-title">Vehicle Rental Dispatch</h3>
          <p class="card-editorial-description">
            Vehicle rental platform enhanced with image recognition capabilities
            for seamless fleet management.
          </p>
        </div>

        <div class="card-editorial">
          <div class="card-editorial-icon">
            <i data-lucide="shopping-basket"></i>
          </div>
          <h3 class="card-editorial-title">Digital Vendor Marketplace</h3>
          <p class="card-editorial-description">
            Digital marketplace connecting local vendors directly to consumers
            beyond physical market stalls.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- 8. GAMES -->
  <section class="section section-alt">
    <div class="container">
      <div class="section-header">
        <p class="eyebrow">Games</p>
        <h2 class="section-title">African Stories Through Play</h2>
        <p class="section-description">
          Interactive experiences rooted in African cities, culture, and civic
          life.
        </p>
      </div>

      <div class="card-grid-editorial cols-3">
        <div class="card-editorial">
          <div class="card-editorial-icon"><i data-lucide="gamepad-2"></i></div>
          <h3 class="card-editorial-title">Digital Expression & Activism</h3>
          <p class="card-editorial-description">
            A safe space for peaceful digital expression through interactive
            gaming, channelling civic voice into play.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- 9. WEBSITES BUILT FOR COMPANIES -->
  <section class="section">
    <div class="container">
      <div class="section-header">
        <p class="eyebrow">Websites Built for Companies</p>
        <h2 class="section-title">Digital Presence for African Institutions</h2>
        <p class="section-description">
          Custom corporate and institutional websites built and maintained under
          Momentum for organisations across Africa.
        </p>
      </div>

      <div class="card-grid-editorial cols-3">
        <div class="card-editorial">
          <div class="card-editorial-icon">
            <i data-lucide="building-2"></i>
          </div>
          <h3 class="card-editorial-title">OBG Website</h3>
          <p class="card-editorial-description">
            Custom institutional website platform built and maintained under
            Momentum for a disability clinic.
          </p>
        </div>

        <div class="card-editorial">
          <div class="card-editorial-icon"><i data-lucide="globe"></i></div>
          <h3 class="card-editorial-title">Victoria Falls Institute</h3>
          <p class="card-editorial-description">
            Organisational website system developed and managed by Momentum for
            the Victoria Falls Regional Institute.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- 10. CTA -->
  <section class="section cta-section">
    <div class="kente-decoration"></div>
    <div class="container">
      <div class="cta-content">
        <h2 class="display-3xl mb-xs">Want to Build the Next One?</h2>
        <p class="text-muted mb-md" style="font-size: var(--text-base);">
          Join a cohort, commission a build, or deploy any of these systems
          into your organisation.
        </p>
        <div class="cta-buttons">
          <a href="/contact" class="btn btn-primary btn-lg">
            <span>Get In Touch</span>
            <i data-lucide="arrow-right"></i>
          </a>
          <a href="/services" class="btn btn-outline btn-lg">
            <span>Our Services</span>
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
