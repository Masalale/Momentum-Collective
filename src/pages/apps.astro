---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Apps & Products | Momentum Collective"
  description="Explore the mobile apps and SaaS products developed by Momentum Collective."
  barbaNamespace="apps"
>
  <!-- 1. PAGE HERO -->
  <section class="hero">
    <div class="container">
      <div class="hero-content">
        <p class="hero-eyebrow">Digital Products</p>
        <h1 class="hero-title display-3xl" data-split>
          Solutions Built for Africa
        </h1>
        <p
          class="hero-subtext"
          style="font-size: var(--text-base); margin: 0 auto; max-width: 600px;"
        >
          Shipping products that serve real communities across the continent.
        </p>
      </div>
    </div>
  </section>

  <!-- 2. MARQUEE -->
  <div class="marquee">
    <div class="marquee-track">
      <div class="marquee-content">
        <span>Nairobi</span><span class="marquee-dot"></span>
        <span>Lagos</span><span class="marquee-dot"></span>
        <span>Accra</span><span class="marquee-dot"></span>
        <span>Cairo</span><span class="marquee-dot"></span>
        <span>Johannesburg</span><span class="marquee-dot"></span>
        <span>Dakar</span><span class="marquee-dot"></span>
        <span>Addis Ababa</span><span class="marquee-dot"></span>
        <span>AfroNative</span><span class="marquee-dot"></span>
        <span>FreshMarikiti</span><span class="marquee-dot"></span>
        <span>Immuno</span><span class="marquee-dot"></span>
        <span>Manoemano</span><span class="marquee-dot"></span>
        <span>Trot</span><span class="marquee-dot"></span>
        <span>Robes</span><span class="marquee-dot"></span>
        <span>Built by African Youth</span>
      </div>
      <div class="marquee-content" aria-hidden="true">
        <span>Nairobi</span><span class="marquee-dot"></span>
        <span>Lagos</span><span class="marquee-dot"></span>
        <span>Accra</span><span class="marquee-dot"></span>
        <span>Cairo</span><span class="marquee-dot"></span>
        <span>Johannesburg</span><span class="marquee-dot"></span>
        <span>Dakar</span><span class="marquee-dot"></span>
        <span>Addis Ababa</span><span class="marquee-dot"></span>
        <span>AfroNative</span><span class="marquee-dot"></span>
        <span>FreshMarikiti</span><span class="marquee-dot"></span>
        <span>Immuno</span><span class="marquee-dot"></span>
        <span>Manoemano</span><span class="marquee-dot"></span>
        <span>Trot</span><span class="marquee-dot"></span>
        <span>Robes</span><span class="marquee-dot"></span>
        <span>Built by African Youth</span>
      </div>
    </div>
  </div>

  <!-- 3. CREATIVE SUITE -->
  <section class="section" style="padding: var(--space-md) 0;">
    <div class="container">
      <div class="section-header" style="margin-bottom: var(--space-sm);">
        <p class="eyebrow">The Creative Suite</p>
        <h2 class="display-3xl mb-xs" data-split>Built to Inspire</h2>
        <p class="text-muted" style="font-size: var(--text-base);">
          Inspiring creativity and preserving culture through MVPs.
        </p>
      </div>

      <div class="card-grid-editorial cols-4">
        <a href="#" class="card-editorial" data-reveal>
          <div class="card-editorial-icon"><i data-lucide="languages"></i></div>
          <div class="card-editorial-tagline">Cultural Preservation</div>
          <h3 class="card-editorial-title">AfroNative</h3>
          <p class="card-editorial-description">
            Helping users learn African mother tongues and bridging generational
            gaps.
          </p>
          <div class="card-editorial-link">
            <span>Discover AfroNative</span><i data-lucide="arrow-right"></i>
          </div>
        </a>

        <a href="/fm-index" class="card-editorial" data-reveal>
          <div class="card-editorial-icon">
            <i data-lucide="shopping-basket"></i>
          </div>
          <div class="card-editorial-tagline">Vendor Marketplace</div>
          <h3 class="card-editorial-title">FreshMarikiti</h3>
          <p class="card-editorial-description">
            Empowering local market vendors to sell and deliver fresh goods
            digitally.
          </p>
          <div class="card-editorial-link">
            <span>Visit FreshMarikiti</span><i data-lucide="arrow-right"></i>
          </div>
        </a>

        <a href="/immuno" class="card-editorial" data-reveal>
          <div class="card-editorial-icon"><i data-lucide="shield"></i></div>
          <div class="card-editorial-tagline">Health & Tracking</div>
          <h3 class="card-editorial-title">Immuno</h3>
          <p class="card-editorial-description">
            Helping hospitals track vaccination progress and send timely
            reminders.
          </p>
          <div class="card-editorial-link">
            <span>Explore Immuno</span><i data-lucide="arrow-right"></i>
          </div>
        </a>

        <a href="#" class="card-editorial" data-reveal>
          <div class="card-editorial-icon"><i data-lucide="gamepad-2"></i></div>
          <div class="card-editorial-tagline">Digital Activism</div>
          <h3 class="card-editorial-title">Manoemano</h3>
          <p class="card-editorial-description">
            A safe space for peaceful digital expression through interactive
            gaming.
          </p>
          <div class="card-editorial-link">
            <span>Play Manoemano</span><i data-lucide="arrow-right"></i>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- 4. BUSINESS SUITE -->
  <section class="section section-alt" style="padding: var(--space-md) 0;">
    <div class="container">
      <div class="section-header" style="margin-bottom: var(--space-sm);">
        <p class="eyebrow">The Business Suite</p>
        <h2 class="display-3xl mb-xs" data-split>SaaS for Operations</h2>
        <p class="text-muted" style="font-size: var(--text-base);">
          Practical tools designed to streamline and support businesses.
        </p>
      </div>

      <div class="card-grid-editorial cols-4">
        <a href="#" class="card-editorial" data-reveal>
          <div class="card-editorial-icon"><i data-lucide="car"></i></div>
          <div class="card-editorial-tagline">Car Rentals</div>
          <h3 class="card-editorial-title">Trot</h3>
          <p class="card-editorial-description">
            Car rentals made easy, transparent, and seamless.
          </p>
          <div class="card-editorial-link">
            <span>Explore Trot</span><i data-lucide="arrow-right"></i>
          </div>
        </a>

        <a href="#" class="card-editorial" data-reveal>
          <div class="card-editorial-icon"><i data-lucide="shirt"></i></div>
          <div class="card-editorial-tagline">Fashion Tech</div>
          <h3 class="card-editorial-title">Robes</h3>
          <p class="card-editorial-description">
            Personalized fashion shopping linked to trends.
          </p>
          <div class="card-editorial-link">
            <span>View Robes</span><i data-lucide="arrow-right"></i>
          </div>
        </a>

        <a href="#" class="card-editorial" data-reveal>
          <div class="card-editorial-icon"><i data-lucide="qr-code"></i></div>
          <div class="card-editorial-tagline">Payments</div>
          <h3 class="card-editorial-title">Mpesa QR</h3>
          <p class="card-editorial-description">
            Simple, secure, and instant mobile payments.
          </p>
          <div class="card-editorial-link">
            <span>Learn More</span><i data-lucide="arrow-right"></i>
          </div>
        </a>

        <a href="#" class="card-editorial" data-reveal>
          <div class="card-editorial-icon">
            <i data-lucide="calendar-check"></i>
          </div>
          <div class="card-editorial-tagline">Scheduling</div>
          <h3 class="card-editorial-title">Booking</h3>
          <p class="card-editorial-description">
            Frictionless reservations and scheduling.
          </p>
          <div class="card-editorial-link">
            <span>Try Booking</span><i data-lucide="arrow-right"></i>
          </div>
        </a>

        <a href="#" class="card-editorial" data-reveal>
          <div class="card-editorial-icon"><i data-lucide="home"></i></div>
          <div class="card-editorial-tagline">Real Estate</div>
          <h3 class="card-editorial-title">Rent Tracker</h3>
          <p class="card-editorial-description">
            Easy property management and tracking.
          </p>
          <div class="card-editorial-link">
            <span>Open Tracker</span><i data-lucide="arrow-right"></i>
          </div>
        </a>

        <a href="#" class="card-editorial" data-reveal>
          <div class="card-editorial-icon"><i data-lucide="package"></i></div>
          <div class="card-editorial-tagline">Supply Chain</div>
          <h3 class="card-editorial-title">Inventory</h3>
          <p class="card-editorial-description">
            Smarter stock control and insights for SMEs.
          </p>
          <div class="card-editorial-link">
            <span>Manage Stock</span><i data-lucide="arrow-right"></i>
          </div>
        </a>

        <a href="#" class="card-editorial" data-reveal>
          <div class="card-editorial-icon"><i data-lucide="book-open"></i></div>
          <div class="card-editorial-tagline">Education</div>
          <h3 class="card-editorial-title">LMS</h3>
          <p class="card-editorial-description">
            Accessible, robust digital learning platform.
          </p>
          <div class="card-editorial-link">
            <span>Explore LMS</span><i data-lucide="arrow-right"></i>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- 5. CTA -->
  <section class="section cta-section" style="padding-top: var(--space-lg);">
    <div class="kente-decoration"></div>
    <div class="container">
      <div class="cta-content">
        <h2 class="display-3xl mb-xs">Have a Product Idea?</h2>
        <p class="text-muted mb-md" style="font-size: var(--text-base);">
          Our team of young African builders is ready to bring your vision to
          life.
        </p>
        <div class="cta-buttons">
          <a href="/contact" class="btn btn-primary btn-lg">
            <span>Get In Touch</span>
            <i data-lucide="arrow-right"></i>
          </a>
          <a href="/services" class="btn btn-outline btn-lg">
            <span>Our Services</span>
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  import { initMarquee } from "../scripts/marquee";
  document.addEventListener("DOMContentLoaded", () => {
    initMarquee();
  });
</script>
