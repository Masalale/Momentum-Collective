---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Apps - Momentum Collective" description="Explore the mobile apps and SaaS products developed by Momentum Collective.">
    <!-- Mobile Apps Section -->
    <section id="apps" class="apps">
        <div class="container">
            <h2 class="section-title">Our Mobile Apps</h2>

            <!-- Creative Suite -->
            <div class="suite">
                <h3 class="suite-title">The Creative Suite</h3>
                <p class="suite-description">A collection of MVPs built to inspire creativity, preserve culture, and
                    expand opportunities:</p>
                <div class="row row-cols-1 row-cols-md-4 g-4 mb-5">

                    <div class="col">
                        <div class="app-card">
                            <div class="app-icon-component">
                                <img src="/assets/afronative-icon.png" alt="AfroNative App Icon" class="img-fluid rounded mx-auto mb-3">
                            </div>
                            <div class="app-info">
                                <h3 class="app-name">AfroNative</h3>
                                <p class="app-tagline">Preserve & practice native languages</p>
                                <p class="app-description">Engaging app to learn African mother tongues; bridging generational language gaps.</p>
                            </div>
                            <a href="#" class="btn btn-primary btn-small">Learn More</a>
                        </div>
                    </div>

                    <div class="col">
                        <div class="app-card">
                            <div class="app-icon-component">
                                <img src="/assets/freshmarikiti-icon.png" alt="FreshMarikiti App Icon" class="img-fluid rounded mx-auto mb-3">
                            </div>
                            <div class="app-info">
                                <h3 class="app-name">FreshMarikiti</h3>
                                <p class="app-tagline">Marketplace for small vendors</p>
                                <p class="app-description">Empowers market vendors (especially women) to sell & deliver goods digitally; expands reach beyond physical stalls.</p>
                            </div>
                            <a href="/fm-index" class="btn btn-primary btn-small">Learn More</a>
                        </div>
                    </div>

                    <div class="col">
                        <div class="app-card">
                            <div class="app-icon-component">
                                <img src="/assets/immuno_logo2.png" alt="Immuno App Icon" class="img-fluid rounded mx-auto mb-3">
                            </div>
                            <div class="app-info">
                                <h3 class="app-name">Immuno</h3>
                                <p class="app-tagline">Immunization tracking & reminders</p>
                                <p class="app-description">Helps hospitals track vaccination progress; sends timely reminders; ensures no immunization milestones are missed.</p>
                            </div>
                            <a href="/immuno" class="btn btn-primary btn-small">Learn More</a>
                        </div>
                    </div>

                    <div class="col">
                        <div class="app-card">
                            <div class="app-icon-component">
                                <i class="fas fa-gamepad fa-2x" style="color: white; position: relative; z-index: 1;"></i>
                            </div>
                            <div class="app-info">
                                <h3 class="app-name">Manoemano</h3>
                                <p class="app-tagline">A platform for peaceful digital expression and activism through gaming.</p>
                            </div>
                            <a href="#" class="btn btn-primary btn-small">Learn More</a>
                        </div>
                    </div>

                </div>
            </div>

            <!-- Business Suite -->
            <div class="suite business-suite">
                <h3 class="suite-title">The Business Suite (SaaS)</h3>
                <p class="suite-description">Practical tools designed to streamline services and support
                    businesses,
                    now available as SaaS products:</p>

                <div class="row row-cols-1 row-cols-md-4 g-4">
                    <div class="col">
                        <div class="app-card">
                            <div class="app-icon-component">
                                <i class="fas fa-car fa-2x" style="color: white; position: relative; z-index: 1;"></i>
                            </div>
                            <div class="app-info">
                                <h3 class="app-name">Trot</h3>
                                <p class="app-tagline">Car rentals made easy and transparent.</p>
                            </div>
                            <a href="#" class="btn btn-primary btn-small">Learn More</a>
                        </div>
                    </div>

                    <div class="col">
                        <div class="app-card">
                            <div class="app-icon-component">
                                <i class="fas fa-tshirt fa-2x" style="color: white; position: relative; z-index: 1;"></i>
                            </div>
                            <div class="app-info">
                                <h3 class="app-name">Robes</h3>
                                <p class="app-tagline">Personalized fashion shopping that links to items from social media.</p>
                            </div>
                            <a href="#" class="btn btn-primary btn-small">Learn More</a>
                        </div>
                    </div>

                    <div class="col">
                        <div class="app-card">
                            <div class="app-icon-component">
                                <i class="fas fa-qrcode fa-2x" style="color: white; position: relative; z-index: 1;"></i>
                            </div>
                            <div class="app-info">
                                <h3 class="app-name">Mpesa QR System</h3>
                                <p class="app-tagline">Simple, secure mobile payments for businesses.</p>
                            </div>
                            <a href="#" class="btn btn-primary btn-small">Learn More</a>
                        </div>
                    </div>

                    <div class="col">
                        <div class="app-card">
                            <div class="app-icon-component">
                                <i class="fas fa-calendar-check fa-2x" style="color: white; position: relative; z-index: 1;"></i>
                            </div>
                            <div class="app-info">
                                <h3 class="app-name">Booking System</h3>
                                <p class="app-tagline">Seamless reservations for businesses and events.</p>
                            </div>
                            <a href="#" class="btn btn-primary btn-small">Learn More</a>
                        </div>
                    </div>

                    <div class="col">
                        <div class="app-card">
                            <div class="app-icon-component">
                                <i class="fas fa-home fa-2x" style="color: white; position: relative; z-index: 1;"></i>
                            </div>
                            <div class="app-info">
                                <h3 class="app-name">Rent Tracker</h3>
                                <p class="app-tagline">Easy property management and automated reminders.</p>
                            </div>
                            <a href="#" class="btn btn-primary btn-small">Learn More</a>
                        </div>
                    </div>

                    <div class="col">
                        <div class="app-card">
                            <div class="app-icon-component">
                                <i class="fas fa-boxes fa-2x" style="color: white; position: relative; z-index: 1;"></i>
                            </div>
                            <div class="app-info">
                                <h3 class="app-name">Inventory System</h3>
                                <p class="app-tagline">Smarter stock control for small and medium-sized enterprises.</p>
                            </div>
                            <a href="#" class="btn btn-primary btn-small">Learn More</a>
                        </div>
                    </div>

                    <div class="col">
                        <div class="app-card">
                            <div class="app-icon-component">
                                <i class="fas fa-graduation-cap fa-2x" style="color: white; position: relative; z-index: 1;"></i>
                            </div>
                            <div class="app-info">
                                <h3 class="app-name">Learning Management System (LMS)</h3>
                                <p class="app-tagline">An accessible digital learning platform for institutions.</p>
                            </div>
                            <a href="#" class="btn btn-primary btn-small">Learn More</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
</BaseLayout>
