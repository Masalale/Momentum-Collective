---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Products | Momentum Collective"
  description="23+ live software systems built and sold by Momentum Labs CLG, SaaS, AI, health, finance, commerce, and enterprise platforms serving African markets."
  barbaNamespace="apps"
>
  <!-- 1. PAGE HERO -->
  <section class="hero">
    <div class="container">
      <div class="hero-content">
        <p class="hero-eyebrow">Live Software Portfolio</p>
        <h1 class="hero-title display-3xl">
          23+ Systems in the Market
        </h1>
        <p
          class="hero-subtext"
          style="font-size: var(--text-base); margin: 0 auto; max-width: 600px;"
        >
          Every product is actively maintained, sold externally, and managed by
          a dedicated team. Not demos, live, revenue-generating systems.
        </p>
      </div>
    </div>
  </section>

  <!-- 2. MARQUEE -->
  <div class="marquee">
    <div class="marquee-track">
      <div class="marquee-content">
        <span>AfroNative</span><span class="marquee-dot"></span>
        <span>FreshMarikiti</span><span class="marquee-dot"></span>
        <span>Manoemano</span><span class="marquee-dot"></span>
        <span>Immunization Tracker</span><span class="marquee-dot"></span>
        <span>TruthGuard</span><span class="marquee-dot"></span>
        <span>CommBridge AI</span><span class="marquee-dot"></span>
        <span>Blockchain Banking</span><span class="marquee-dot"></span>
        <span>SeamlessHR</span><span class="marquee-dot"></span>
        <span>Construction Manager</span><span class="marquee-dot"></span>
        <span>Hospital STRA</span><span class="marquee-dot"></span>
        <span>Trot</span><span class="marquee-dot"></span>
        <span>Robes</span><span class="marquee-dot"></span>
        <span>InsightKE</span><span class="marquee-dot"></span>
        <span>Built by African Youth</span>
      </div>
      <div class="marquee-content" aria-hidden="true">
        <span>AfroNative</span><span class="marquee-dot"></span>
        <span>FreshMarikiti</span><span class="marquee-dot"></span>
        <span>Manoemano</span><span class="marquee-dot"></span>
        <span>Immunization Tracker</span><span class="marquee-dot"></span>
        <span>TruthGuard</span><span class="marquee-dot"></span>
        <span>CommBridge AI</span><span class="marquee-dot"></span>
        <span>Blockchain Banking</span><span class="marquee-dot"></span>
        <span>SeamlessHR</span><span class="marquee-dot"></span>
        <span>Construction Manager</span><span class="marquee-dot"></span>
        <span>Hospital STRA</span><span class="marquee-dot"></span>
        <span>Trot</span><span class="marquee-dot"></span>
        <span>Robes</span><span class="marquee-dot"></span>
        <span>InsightKE</span><span class="marquee-dot"></span>
        <span>Built by African Youth</span>
      </div>
    </div>
  </div>

  <!-- 3. CREATIVE & CULTURE SUITE -->
  <section class="section">
    <div class="container">
      <div class="section-header">
        <p class="eyebrow">Creative & Culture</p>
        <h2 class="section-title">Preserving Heritage Through Tech</h2>
        <p class="section-description">
          Platforms that connect communities and safeguard African cultural
          identity.
        </p>
      </div>

      <div class="card-grid-editorial cols-3">
        <a href="#" class="card-editorial" data-reveal>
          <div class="card-editorial-icon"><i data-lucide="languages"></i></div>
          <div class="card-editorial-tagline">Cultural Preservation</div>
          <h3 class="card-editorial-title">AfroNative</h3>
          <p class="card-editorial-description">
            Language-learning platform focused on preserving and teaching
            African dialects across generations.
          </p>
          <div class="card-editorial-link">
            <span>Discover AfroNative</span><i data-lucide="arrow-right"></i>
          </div>
        </a>

        <a href="/fm-index" class="card-editorial" data-reveal>
          <div class="card-editorial-icon">
            <i data-lucide="shopping-basket"></i>
          </div>
          <div class="card-editorial-tagline">Vendor Marketplace</div>
          <h3 class="card-editorial-title">FreshMarikiti</h3>
          <p class="card-editorial-description">
            Digital marketplace connecting local vendors directly to consumers
            beyond physical market stalls.
          </p>
          <div class="card-editorial-link">
            <span>Visit FreshMarikiti</span><i data-lucide="arrow-right"></i>
          </div>
        </a>

        <a href="#" class="card-editorial" data-reveal>
          <div class="card-editorial-icon"><i data-lucide="gamepad-2"></i></div>
          <div class="card-editorial-tagline">Digital Activism</div>
          <h3 class="card-editorial-title">Manoemano</h3>
          <p class="card-editorial-description">
            A safe space for peaceful digital expression through interactive
            gaming, channelling civic voice into play.
          </p>
          <div class="card-editorial-link">
            <span>Play Manoemano</span><i data-lucide="arrow-right"></i>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- 4. HEALTH & INSTITUTIONAL SUITE -->
  <section class="section section-alt">
    <div class="container">
      <div class="section-header">
        <p class="eyebrow">Health & Institutional</p>
        <h2 class="section-title">Built for Impact at Scale</h2>
        <p class="section-description">
          Digital systems for hospitals, clinics, and institutions, streamlining
          operations and improving outcomes.
        </p>
      </div>

      <div class="card-grid-editorial cols-3">
        <a href="#" class="card-editorial" data-reveal>
          <div class="card-editorial-icon"><i data-lucide="shield"></i></div>
          <div class="card-editorial-tagline">Vaccination Management</div>
          <h3 class="card-editorial-title">Immunization Tracker</h3>
          <p class="card-editorial-description">
            Digital health and immunization management platform enabling
            vaccination tracking, structured reporting, and clinic coordination.
          </p>
          <div class="card-editorial-link">
            <span>Explore Immuno</span><i data-lucide="arrow-right"></i>
          </div>
        </a>

        <a href="#" class="card-editorial" data-reveal>
          <div class="card-editorial-icon"><i data-lucide="activity"></i></div>
          <div class="card-editorial-tagline">Hospital Operations</div>
          <h3 class="card-editorial-title">Hospital STRA System</h3>
          <p class="card-editorial-description">
            Digital hospital management system streamlining patient flow,
            medical records, staff coordination, and operational reporting.
          </p>
          <div class="card-editorial-link">
            <span>Learn More</span><i data-lucide="arrow-right"></i>
          </div>
        </a>

        <a href="#" class="card-editorial" data-reveal>
          <div class="card-editorial-icon">
            <i data-lucide="building-2"></i>
          </div>
          <div class="card-editorial-tagline">Institutional Website</div>
          <h3 class="card-editorial-title">OBG Website</h3>
          <p class="card-editorial-description">
            Custom institutional website platform built and maintained under
            Momentum for a disability clinic.
          </p>
          <div class="card-editorial-link">
            <span>Learn More</span><i data-lucide="arrow-right"></i>
          </div>
        </a>

        <a href="#" class="card-editorial" data-reveal>
          <div class="card-editorial-icon"><i data-lucide="globe"></i></div>
          <div class="card-editorial-tagline">Regional Institute</div>
          <h3 class="card-editorial-title">Victoria Falls Institute</h3>
          <p class="card-editorial-description">
            Organisational website system developed and managed by Momentum for
            the Victoria Falls Regional Institute.
          </p>
          <div class="card-editorial-link">
            <span>Learn More</span><i data-lucide="arrow-right"></i>
          </div>
        </a>

        <a href="#" class="card-editorial" data-reveal>
          <div class="card-editorial-icon"><i data-lucide="book-open"></i></div>
          <div class="card-editorial-tagline">Education</div>
          <h3 class="card-editorial-title">LMS</h3>
          <p class="card-editorial-description">
            Digital learning platform for schools, institutions, and training
            programs, accessible and robust.
          </p>
          <div class="card-editorial-link">
            <span>Explore LMS</span><i data-lucide="arrow-right"></i>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- 5. BUSINESS OPERATIONS SUITE -->
  <section class="section">
    <div class="container">
      <div class="section-header">
        <p class="eyebrow">Business Operations</p>
        <h2 class="section-title">SaaS for Growing Businesses</h2>
        <p class="section-description">
          Practical operations tools addressing real inefficiencies across
          African SMEs and enterprises.
        </p>
      </div>

      <div class="card-grid-editorial cols-3">
        <a href="#" class="card-editorial" data-reveal>
          <div class="card-editorial-icon"><i data-lucide="shirt"></i></div>
          <div class="card-editorial-tagline">Fashion Tech</div>
          <h3 class="card-editorial-title">Robes</h3>
          <p class="card-editorial-description">
            Smart fashion commerce platform featuring intelligent sizing
            technology.
          </p>
          <div class="card-editorial-link">
            <span>View Robes</span><i data-lucide="arrow-right"></i>
          </div>
        </a>

        <a href="#" class="card-editorial" data-reveal>
          <div class="card-editorial-icon"><i data-lucide="car"></i></div>
          <div class="card-editorial-tagline">Vehicle Rental</div>
          <h3 class="card-editorial-title">Trot</h3>
          <p class="card-editorial-description">
            Vehicle rental platform enhanced with image recognition capabilities
            for seamless fleet management.
          </p>
          <div class="card-editorial-link">
            <span>Explore Trot</span><i data-lucide="arrow-right"></i>
          </div>
        </a>

        <a href="/immuno" class="card-editorial" data-reveal>
          <div class="card-editorial-icon"><i data-lucide="shield"></i></div>
          <div class="card-editorial-tagline">Vaccination Management</div>
          <h3 class="card-editorial-title">Immunization Tracker</h3>
          <p class="card-editorial-description">
            Digital health and immunization management platform enabling
            vaccination tracking, structured reporting, and clinic coordination.
          </p>
          <div class="card-editorial-link">
            <span>Explore Immuno</span><i data-lucide="arrow-right"></i>
          </div>
        </a>

        <a href="#" class="card-editorial" data-reveal>
          <div class="card-editorial-icon"><i data-lucide="package"></i></div>
          <div class="card-editorial-tagline">Supply Chain</div>
          <h3 class="card-editorial-title">Inventory System</h3>
          <p class="card-editorial-description">
            Smart stock management for SMEs with forecasting and intelligent
            restock insights.
          </p>
          <div class="card-editorial-link">
            <span>Manage Stock</span><i data-lucide="arrow-right"></i>
          </div>
        </a>

        <a href="#" class="card-editorial" data-reveal>
          <div class="card-editorial-icon">
            <i data-lucide="calendar-check"></i>
          </div>
          <div class="card-editorial-tagline">Scheduling</div>
          <h3 class="card-editorial-title">Booking System</h3>
          <p class="card-editorial-description">
            Appointment scheduling and client management platform for service
            providers.
          </p>
          <div class="card-editorial-link">
            <span>Try Booking</span><i data-lucide="arrow-right"></i>
          </div>
        </a>

        <a href="#" class="card-editorial" data-reveal>
          <div class="card-editorial-icon"><i data-lucide="home"></i></div>
          <div class="card-editorial-tagline">Property Management</div>
          <h3 class="card-editorial-title">Rent Tracker</h3>
          <p class="card-editorial-description">
            Property and tenant management system with WhatsApp integration and
            automated tracking.
          </p>
          <div class="card-editorial-link">
            <span>Open Tracker</span><i data-lucide="arrow-right"></i>
          </div>
        </a>

        <a href="#" class="card-editorial" data-reveal>
          <div class="card-editorial-icon"><i data-lucide="qr-code"></i></div>
          <div class="card-editorial-tagline">Payments</div>
          <h3 class="card-editorial-title">M-Pesa QR System</h3>
          <p class="card-editorial-description">
            Fast, secure, cashless payment solution for businesses and
            merchants.
          </p>
          <div class="card-editorial-link">
            <span>Learn More</span><i data-lucide="arrow-right"></i>
          </div>
        </a>

        <a href="#" class="card-editorial" data-reveal>
          <div class="card-editorial-icon"><i data-lucide="hard-hat"></i></div>
          <div class="card-editorial-tagline">Project Management</div>
          <h3 class="card-editorial-title">Construction Manager</h3>
          <p class="card-editorial-description">
            Platform for construction managers to monitor site operations, track
            materials, manage budgets, and assign tasks in real time.
          </p>
          <div class="card-editorial-link">
            <span>Learn More</span><i data-lucide="arrow-right"></i>
          </div>
        </a>

        <a href="#" class="card-editorial" data-reveal>
          <div class="card-editorial-icon"><i data-lucide="users"></i></div>
          <div class="card-editorial-tagline">Workforce Management</div>
          <h3 class="card-editorial-title">SeamlessHR</h3>
          <p class="card-editorial-description">
            Workforce management platform handling employee records, attendance,
            and payroll support.
          </p>
          <div class="card-editorial-link">
            <span>Explore SeamlessHR</span><i data-lucide="arrow-right"></i>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- 6. AI & INTELLIGENCE SUITE -->
  <section class="section section-alt">
    <div class="container">
      <div class="section-header">
        <p class="eyebrow">AI & Intelligence</p>
        <h2 class="section-title">AI-Forward, Africa-Focused</h2>
        <p class="section-description">
          Embedding intelligence across finance, healthcare, marketing, HR, and
          governance.
        </p>
      </div>

      <div class="card-grid-editorial cols-3">
        <a href="#" class="card-editorial" data-reveal>
          <div class="card-editorial-icon">
            <i data-lucide="message-square"></i>
          </div>
          <div class="card-editorial-tagline">Customer Support</div>
          <h3 class="card-editorial-title">AI Chatbot</h3>
          <p class="card-editorial-description">
            24/7 AI-powered automated customer support system deployable across
            businesses and institutions.
          </p>
          <div class="card-editorial-link">
            <span>Learn More</span><i data-lucide="arrow-right"></i>
          </div>
        </a>

        <a href="#" class="card-editorial" data-reveal>
          <div class="card-editorial-icon">
            <i data-lucide="shield-check"></i>
          </div>
          <div class="card-editorial-tagline">Misinformation Detection</div>
          <h3 class="card-editorial-title">TruthGuard</h3>
          <p class="card-editorial-description">
            AI credibility analysis tool that scores text and screenshots for
            misinformation risk.
          </p>
          <div class="card-editorial-link">
            <span>Explore TruthGuard</span><i data-lucide="arrow-right"></i>
          </div>
        </a>

        <a href="#" class="card-editorial" data-reveal>
          <div class="card-editorial-icon"><i data-lucide="globe"></i></div>
          <div class="card-editorial-tagline">Multilingual AI</div>
          <h3 class="card-editorial-title">CommBridge AI</h3>
          <p class="card-editorial-description">
            Multilingual conversational AI platform with real-time translation
            bridging language gaps across Africa.
          </p>
          <div class="card-editorial-link">
            <span>Explore CommBridge</span><i data-lucide="arrow-right"></i>
          </div>
        </a>

        <a href="#" class="card-editorial" data-reveal>
          <div class="card-editorial-icon">
            <i data-lucide="bar-chart-2"></i>
          </div>
          <div class="card-editorial-tagline">Social CRM</div>
          <h3 class="card-editorial-title">InsightKE</h3>
          <p class="card-editorial-description">
            AI-powered social CRM integrating Instagram, WhatsApp, and digital
            communication channels into a unified intelligence layer.
          </p>
          <div class="card-editorial-link">
            <span>Explore InsightKE</span><i data-lucide="arrow-right"></i>
          </div>
        </a>

        <a href="#" class="card-editorial" data-reveal>
          <div class="card-editorial-icon"><i data-lucide="scan-line"></i></div>
          <div class="card-editorial-tagline">Content Authenticity</div>
          <h3 class="card-editorial-title">AI Disprover</h3>
          <p class="card-editorial-description">
            Browser extension that detects AI-generated content in real time,
            preserving information integrity.
          </p>
          <div class="card-editorial-link">
            <span>Learn More</span><i data-lucide="arrow-right"></i>
          </div>
        </a>

        <a href="#" class="card-editorial" data-reveal>
          <div class="card-editorial-icon"><i data-lucide="megaphone"></i></div>
          <div class="card-editorial-tagline">Marketing Automation</div>
          <h3 class="card-editorial-title">Marketing Hack</h3>
          <p class="card-editorial-description">
            SME marketing automation system for WhatsApp and SMS campaigns,
            reach more customers with less effort.
          </p>
          <div class="card-editorial-link">
            <span>Learn More</span><i data-lucide="arrow-right"></i>
          </div>
        </a>

        <a href="#" class="card-editorial" data-reveal>
          <div class="card-editorial-icon"><i data-lucide="filter"></i></div>
          <div class="card-editorial-tagline">Content Safety</div>
          <h3 class="card-editorial-title">Toxic Content Moderator</h3>
          <p class="card-editorial-description">
            AI moderation system that detects harmful content and suggests
            constructive rewrites for safer digital spaces.
          </p>
          <div class="card-editorial-link">
            <span>Learn More</span><i data-lucide="arrow-right"></i>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- 7. COMMERCE & FINANCE SUITE -->
  <section class="section">
    <div class="container">
      <div class="section-header">
        <p class="eyebrow">Commerce & Finance</p>
        <h2 class="section-title">Built for the African Economy</h2>
        <p class="section-description">
          Commerce and financial infrastructure designed for the realities of
          African markets.
        </p>
      </div>

      <div
        class="card-grid-editorial"
        style="max-width: 760px; margin-left: auto; margin-right: auto;"
      >
        <a href="#" class="card-editorial" data-reveal>
          <div class="card-editorial-icon"><i data-lucide="lock"></i></div>
          <div class="card-editorial-tagline">Secure Banking</div>
          <h3 class="card-editorial-title">Blockchain Banking</h3>
          <p class="card-editorial-description">
            Secure cross-branch banking infrastructure with immutable audit
            trails, permissioned access, and full transaction transparency.
          </p>
          <div class="card-editorial-link">
            <span>Learn More</span><i data-lucide="arrow-right"></i>
          </div>
        </a>

        <a href="#" class="card-editorial" data-reveal>
          <div class="card-editorial-icon">
            <i data-lucide="credit-card"></i>
          </div>
          <div class="card-editorial-tagline">Financial Recovery</div>
          <h3 class="card-editorial-title">Debt Collection System</h3>
          <p class="card-editorial-description">
            Digital debt management solution designed for SACCOs, micro-lenders,
            and financial institutions.
          </p>
          <div class="card-editorial-link">
            <span>Learn More</span><i data-lucide="arrow-right"></i>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- 8. CTA -->
  <section class="section cta-section">
    <div class="kente-decoration"></div>
    <div class="container">
      <div class="cta-content">
        <h2 class="display-3xl mb-xs">Want to Build the Next One?</h2>
        <p class="text-muted mb-md" style="font-size: var(--text-base);">
          Join a cohort, partner with our teams, or deploy any of these systems
          into your organisation.
        </p>
        <div class="cta-buttons">
          <a href="/contact" class="btn btn-primary btn-lg">
            <span>Get In Touch</span>
            <i data-lucide="arrow-right"></i>
          </a>
          <a href="/services" class="btn btn-outline btn-lg">
            <span>Our Services</span>
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  import { initMarquee } from "../scripts/marquee";
  document.addEventListener("DOMContentLoaded", () => {
    initMarquee();
  });
</script>
