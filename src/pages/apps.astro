---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Products | Momentum Collective"
  description="23+ live software systems built and sold by Momentum Labs CLG, SaaS, AI, health, finance, commerce, and enterprise platforms serving African markets."
  barbaNamespace="apps"
>
  <!-- 1. PAGE HERO -->
  <section class="hero">
    <div class="container">
      <div class="hero-content">
        <p class="hero-eyebrow">Live Software Portfolio</p>
        <h1 class="hero-title display-3xl">
          42+ Systems in the Market
        </h1>
        <p
          class="hero-subtext"
          style="font-size: var(--text-base); margin: 0 auto; max-width: 600px;"
        >
          Cohort-built platforms, AI tools, and hackathon projects — all
          actively maintained and deployed into African markets.
        </p>
      </div>
    </div>
  </section>

  <!-- 2. MARQUEE -->
  <div class="marquee">
    <div class="marquee-track">
      <div class="marquee-content">
        <span>AfroNative</span><span class="marquee-dot"></span>
        <span>FreshMarikiti</span><span class="marquee-dot"></span>
        <span>Manoemano</span><span class="marquee-dot"></span>
        <span>Immunization Tracker</span><span class="marquee-dot"></span>
        <span>TruthGuard</span><span class="marquee-dot"></span>
        <span>CommBridge AI</span><span class="marquee-dot"></span>
        <span>Blockchain Banking</span><span class="marquee-dot"></span>
        <span>SeamlessHR</span><span class="marquee-dot"></span>
        <span>CarePilot</span><span class="marquee-dot"></span>
        <span>NairobiAlert</span><span class="marquee-dot"></span>
        <span>Construction Manager</span><span class="marquee-dot"></span>
        <span>Hospital STRA</span><span class="marquee-dot"></span>
        <span>AkiLimo</span><span class="marquee-dot"></span>
        <span>ImaraSOS</span><span class="marquee-dot"></span>
        <span>Trot</span><span class="marquee-dot"></span>
        <span>Robes</span><span class="marquee-dot"></span>
        <span>Mentora</span><span class="marquee-dot"></span>
        <span>InsightKE</span><span class="marquee-dot"></span>
        <span>AMANI GRID</span><span class="marquee-dot"></span>
        <span>NuruLearn</span><span class="marquee-dot"></span>
        <span>Nexus Forensic</span><span class="marquee-dot"></span>
        <span>Built by African Youth</span>
      </div>
      <div class="marquee-content" aria-hidden="true">
        <span>AfroNative</span><span class="marquee-dot"></span>
        <span>FreshMarikiti</span><span class="marquee-dot"></span>
        <span>Manoemano</span><span class="marquee-dot"></span>
        <span>Immunization Tracker</span><span class="marquee-dot"></span>
        <span>TruthGuard</span><span class="marquee-dot"></span>
        <span>CommBridge AI</span><span class="marquee-dot"></span>
        <span>Blockchain Banking</span><span class="marquee-dot"></span>
        <span>SeamlessHR</span><span class="marquee-dot"></span>
        <span>CarePilot</span><span class="marquee-dot"></span>
        <span>NairobiAlert</span><span class="marquee-dot"></span>
        <span>Construction Manager</span><span class="marquee-dot"></span>
        <span>Hospital STRA</span><span class="marquee-dot"></span>
        <span>AkiLimo</span><span class="marquee-dot"></span>
        <span>ImaraSOS</span><span class="marquee-dot"></span>
        <span>Trot</span><span class="marquee-dot"></span>
        <span>Robes</span><span class="marquee-dot"></span>
        <span>Mentora</span><span class="marquee-dot"></span>
        <span>InsightKE</span><span class="marquee-dot"></span>
        <span>AMANI GRID</span><span class="marquee-dot"></span>
        <span>NuruLearn</span><span class="marquee-dot"></span>
        <span>Nexus Forensic</span><span class="marquee-dot"></span>
        <span>Built by African Youth</span>
      </div>
    </div>
  </div>

  <!-- 3. CREATIVE & CULTURE SUITE -->
  <section class="section">
    <div class="container">
      <div class="section-header">
        <p class="eyebrow">Creative & Culture</p>
        <h2 class="section-title">Preserving Heritage Through Tech</h2>
        <p class="section-description">
          Platforms that connect communities and safeguard African cultural
          identity.
        </p>
      </div>

      <div class="card-grid-editorial cols-3">
        <div class="card-editorial" data-reveal>
          <div class="card-editorial-icon"><i data-lucide="languages"></i></div>
          <div class="card-editorial-tagline">Cultural Preservation</div>
          <h3 class="card-editorial-title">AfroNative</h3>
          <p class="card-editorial-description">
            Language-learning platform focused on preserving and teaching
            African dialects across generations.
          </p>
        </div>

        <div class="card-editorial" data-reveal>
          <div class="card-editorial-icon">
            <i data-lucide="shopping-basket"></i>
          </div>
          <div class="card-editorial-tagline">Vendor Marketplace</div>
          <h3 class="card-editorial-title">FreshMarikiti</h3>
          <p class="card-editorial-description">
            Digital marketplace connecting local vendors directly to consumers
            beyond physical market stalls.
          </p>
        </div>

        <div class="card-editorial" data-reveal>
          <div class="card-editorial-icon"><i data-lucide="gamepad-2"></i></div>
          <div class="card-editorial-tagline">Digital Activism</div>
          <h3 class="card-editorial-title">Manoemano</h3>
          <p class="card-editorial-description">
            A safe space for peaceful digital expression through interactive
            gaming, channelling civic voice into play.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- 4. HEALTH & INSTITUTIONAL SUITE -->
  <section class="section section-alt">
    <div class="container">
      <div class="section-header">
        <p class="eyebrow">Health & Institutional</p>
        <h2 class="section-title">Built for Impact at Scale</h2>
        <p class="section-description">
          Digital systems for hospitals, clinics, and institutions, streamlining
          operations and improving outcomes.
        </p>
      </div>

      <div class="card-grid-editorial cols-3">
        <div class="card-editorial" data-reveal>
          <div class="card-editorial-icon"><i data-lucide="shield"></i></div>
          <div class="card-editorial-tagline">Vaccination Management</div>
          <h3 class="card-editorial-title">Immunization Tracker</h3>
          <p class="card-editorial-description">
            Digital health and immunization management platform enabling
            vaccination tracking, structured reporting, and clinic coordination.
          </p>
        </div>

        <div class="card-editorial" data-reveal>
          <div class="card-editorial-icon"><i data-lucide="activity"></i></div>
          <div class="card-editorial-tagline">Hospital Operations</div>
          <h3 class="card-editorial-title">Hospital STRA System</h3>
          <p class="card-editorial-description">
            Digital hospital management system streamlining patient flow,
            medical records, staff coordination, and operational reporting.
          </p>
        </div>

        <div class="card-editorial" data-reveal>
          <div class="card-editorial-icon">
            <i data-lucide="building-2"></i>
          </div>
          <div class="card-editorial-tagline">Institutional Website</div>
          <h3 class="card-editorial-title">OBG Website</h3>
          <p class="card-editorial-description">
            Custom institutional website platform built and maintained under
            Momentum for a disability clinic.
          </p>
        </div>

        <div class="card-editorial" data-reveal>
          <div class="card-editorial-icon"><i data-lucide="globe"></i></div>
          <div class="card-editorial-tagline">Regional Institute</div>
          <h3 class="card-editorial-title">Victoria Falls Institute</h3>
          <p class="card-editorial-description">
            Organisational website system developed and managed by Momentum for
            the Victoria Falls Regional Institute.
          </p>
        </div>

        <div class="card-editorial" data-reveal>
          <div class="card-editorial-icon"><i data-lucide="book-open"></i></div>
          <div class="card-editorial-tagline">Education</div>
          <h3 class="card-editorial-title">LMS</h3>
          <p class="card-editorial-description">
            Digital learning platform for schools, institutions, and training
            programs, accessible and robust.
          </p>
        </div>

        <!-- Africa Forward Hackathon — Health & Education -->
        <div class="card-editorial" data-reveal>
          <div class="card-editorial-icon"><i data-lucide="map-pin-plus"></i></div>
          <div class="card-editorial-tagline">Healthcare Navigation <span class="hackathon-badge">Africa Forward</span></div>
          <h3 class="card-editorial-title">CarePilot</h3>
          <p class="card-editorial-description">
            Geospatial healthcare navigation platform helping Nairobi residents locate verified clinics, pharmacies, and emergency services — optimised for low-bandwidth environments.
          </p>
        </div>

        <div class="card-editorial" data-reveal>
          <div class="card-editorial-icon"><i data-lucide="pill"></i></div>
          <div class="card-editorial-tagline">Medicine Availability <span class="hackathon-badge">Africa Forward</span></div>
          <h3 class="card-editorial-title">MedAccess</h3>
          <p class="card-editorial-description">
            Healthcare availability dashboard letting clinics update medicine stock in real time while patients view availability on an interactive map.
          </p>
        </div>

        <div class="card-editorial" data-reveal>
          <div class="card-editorial-icon"><i data-lucide="baby"></i></div>
          <div class="card-editorial-tagline">Maternal Health <span class="hackathon-badge">Africa Forward</span></div>
          <h3 class="card-editorial-title">MediBora</h3>
          <p class="card-editorial-description">
            Maternal health monitoring platform detecting high-risk pregnancies early, improving communication between expectant mothers and rural healthcare providers.
          </p>
        </div>

        <div class="card-editorial" data-reveal>
          <div class="card-editorial-icon"><i data-lucide="stethoscope"></i></div>
          <div class="card-editorial-tagline">Healthcare Compliance <span class="hackathon-badge">Africa Forward</span></div>
          <h3 class="card-editorial-title">Nexus Forensic</h3>
          <p class="card-editorial-description">
            Digital medical compliance auditing platform converting government healthcare protocols into computable rules and verifying hospital practices with AI-assisted analysis.
          </p>
        </div>

        <div class="card-editorial" data-reveal>
          <div class="card-editorial-icon"><i data-lucide="fingerprint"></i></div>
          <div class="card-editorial-tagline">Refugee Identity <span class="hackathon-badge">Africa Forward</span></div>
          <h3 class="card-editorial-title">SafeID</h3>
          <p class="card-editorial-description">
            Digital identity and aid access platform for refugees — blockchain-verified profiles, secure document storage, and NGO interaction via chatbot and USSD.
          </p>
        </div>

        <div class="card-editorial" data-reveal>
          <div class="card-editorial-icon"><i data-lucide="message-circle"></i></div>
          <div class="card-editorial-tagline">SMS Education <span class="hackathon-badge">Africa Forward</span></div>
          <h3 class="card-editorial-title">Somo</h3>
          <p class="card-editorial-description">
            AI-powered tutoring system delivered through SMS, enabling displaced students to learn using basic mobile phones with adaptive quizzes and personalised feedback.
          </p>
        </div>

        <div class="card-editorial" data-reveal>
          <div class="card-editorial-icon"><i data-lucide="brain-circuit"></i></div>
          <div class="card-editorial-tagline">Offline Learning <span class="hackathon-badge">Africa Forward</span></div>
          <h3 class="card-editorial-title">NuruLearn</h3>
          <p class="card-editorial-description">
            AI-powered learning platform for displaced students with AI tutor avatars, interactive modules, and virtual STEM labs — all optimised for low-bandwidth environments.
          </p>
        </div>

        <div class="card-editorial" data-reveal>
          <div class="card-editorial-icon"><i data-lucide="tablet-smartphone"></i></div>
          <div class="card-editorial-tagline">Education Access <span class="hackathon-badge">Africa Forward</span></div>
          <h3 class="card-editorial-title">EduFlow</h3>
          <p class="card-editorial-description">
            Offline-first education platform providing mobile learning apps, SMS lessons, and USSD assessments with AI-driven adaptive quizzes for humanitarian contexts.
          </p>
        </div>

        <div class="card-editorial" data-reveal>
          <div class="card-editorial-icon"><i data-lucide="badge-check"></i></div>
          <div class="card-editorial-tagline">Credential Verification <span class="hackathon-badge">Africa Forward</span></div>
          <h3 class="card-editorial-title">Mentora</h3>
          <p class="card-editorial-description">
            Blockchain-based credential verification and scholarship transparency platform — institutions issue tamper-proof digital certificates while donors track fund distribution.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- 5. BUSINESS OPERATIONS SUITE -->
  <section class="section">
    <div class="container">
      <div class="section-header">
        <p class="eyebrow">Business Operations</p>
        <h2 class="section-title">SaaS for Growing Businesses</h2>
        <p class="section-description">
          Practical operations tools addressing real inefficiencies across
          African SMEs and enterprises.
        </p>
      </div>

      <div class="card-grid-editorial cols-3">
        <div class="card-editorial" data-reveal>
          <div class="card-editorial-icon"><i data-lucide="shirt"></i></div>
          <div class="card-editorial-tagline">Fashion Tech</div>
          <h3 class="card-editorial-title">Robes</h3>
          <p class="card-editorial-description">
            Smart fashion commerce platform featuring intelligent sizing
            technology.
          </p>
        </div>

        <div class="card-editorial" data-reveal>
          <div class="card-editorial-icon"><i data-lucide="car"></i></div>
          <div class="card-editorial-tagline">Vehicle Rental</div>
          <h3 class="card-editorial-title">Trot</h3>
          <p class="card-editorial-description">
            Vehicle rental platform enhanced with image recognition capabilities
            for seamless fleet management.
          </p>
        </div>

        <div class="card-editorial" data-reveal>
          <div class="card-editorial-icon"><i data-lucide="package"></i></div>
          <div class="card-editorial-tagline">Supply Chain</div>
          <h3 class="card-editorial-title">Inventory System</h3>
          <p class="card-editorial-description">
            Smart stock management for SMEs with forecasting and intelligent
            restock insights.
          </p>
        </div>

        <div class="card-editorial" data-reveal>
          <div class="card-editorial-icon">
            <i data-lucide="calendar-check"></i>
          </div>
          <div class="card-editorial-tagline">Scheduling</div>
          <h3 class="card-editorial-title">Booking System</h3>
          <p class="card-editorial-description">
            Appointment scheduling and client management platform for service
            providers.
          </p>
        </div>

        <div class="card-editorial" data-reveal>
          <div class="card-editorial-icon"><i data-lucide="home"></i></div>
          <div class="card-editorial-tagline">Property Management</div>
          <h3 class="card-editorial-title">Rent Tracker</h3>
          <p class="card-editorial-description">
            Property and tenant management system with WhatsApp integration and
            automated tracking.
          </p>
        </div>

        <div class="card-editorial" data-reveal>
          <div class="card-editorial-icon"><i data-lucide="qr-code"></i></div>
          <div class="card-editorial-tagline">Payments</div>
          <h3 class="card-editorial-title">M-Pesa QR System</h3>
          <p class="card-editorial-description">
            Fast, secure, cashless payment solution for businesses and
            merchants.
          </p>
        </div>

        <div class="card-editorial" data-reveal>
          <div class="card-editorial-icon"><i data-lucide="hard-hat"></i></div>
          <div class="card-editorial-tagline">Project Management</div>
          <h3 class="card-editorial-title">Construction Manager</h3>
          <p class="card-editorial-description">
            Platform for construction managers to monitor site operations, track
            materials, manage budgets, and assign tasks in real time.
          </p>
        </div>

        <div class="card-editorial" data-reveal>
          <div class="card-editorial-icon"><i data-lucide="users"></i></div>
          <div class="card-editorial-tagline">Workforce Management</div>
          <h3 class="card-editorial-title">SeamlessHR</h3>
          <p class="card-editorial-description">
            Workforce management platform handling employee records, attendance,
            and payroll support.
          </p>
        </div>

        <!-- Africa Forward Hackathon — Crisis & Community Systems -->
        <div class="card-editorial" data-reveal>
          <div class="card-editorial-icon"><i data-lucide="droplets"></i></div>
          <div class="card-editorial-tagline">Water Management <span class="hackathon-badge">Africa Forward</span></div>
          <h3 class="card-editorial-title">Majiminder</h3>
          <p class="card-editorial-description">
            Community water access platform letting residents track supply schedules, report shortages, and receive availability alerts in real time.
          </p>
        </div>

        <div class="card-editorial" data-reveal>
          <div class="card-editorial-icon"><i data-lucide="ambulance"></i></div>
          <div class="card-editorial-tagline">Emergency Dispatch <span class="hackathon-badge">Africa Forward</span></div>
          <h3 class="card-editorial-title">OkoaRoute</h3>
          <p class="card-editorial-description">
            Offline-first USSD medical dispatch system connecting emergencies with nearby boda boda riders for rapid hospital transport without internet access.
          </p>
        </div>

        <div class="card-editorial" data-reveal>
          <div class="card-editorial-icon"><i data-lucide="cloud-rain"></i></div>
          <div class="card-editorial-tagline">Disaster Response <span class="hackathon-badge">Africa Forward</span></div>
          <h3 class="card-editorial-title">NairobiAlert</h3>
          <p class="card-editorial-description">
            Flood crisis response platform enabling citizen incident reporting via web, SMS, or USSD while coordinators manage response through a real-time geospatial dashboard.
          </p>
        </div>

        <div class="card-editorial" data-reveal>
          <div class="card-editorial-icon"><i data-lucide="map-pin"></i></div>
          <div class="card-editorial-tagline">Crisis Coordination <span class="hackathon-badge">Africa Forward</span></div>
          <h3 class="card-editorial-title">AMANI GRID</h3>
          <p class="card-editorial-description">
            Crisis coordination platform converting community reports into structured emergency response actions with geospatial mapping and responder routing.
          </p>
        </div>

        <div class="card-editorial" data-reveal>
          <div class="card-editorial-icon"><i data-lucide="heart-handshake"></i></div>
          <div class="card-editorial-tagline">Humanitarian Aid <span class="hackathon-badge">Africa Forward</span></div>
          <h3 class="card-editorial-title">ReliefLink</h3>
          <p class="card-editorial-description">
            Centralised platform connecting individuals in crisis with nearby shelters, medical facilities, and volunteers.
          </p>
        </div>

        <div class="card-editorial" data-reveal>
          <div class="card-editorial-icon"><i data-lucide="siren"></i></div>
          <div class="card-editorial-tagline">Emergency Response <span class="hackathon-badge">Africa Forward</span></div>
          <h3 class="card-editorial-title">ImaraSOS</h3>
          <p class="card-editorial-description">
            Next-generation emergency response platform for instant help requests during medical emergencies, fires, accidents, and security threats — works even when infrastructure fails.
          </p>
        </div>

        <div class="card-editorial" data-reveal>
          <div class="card-editorial-icon"><i data-lucide="bell"></i></div>
          <div class="card-editorial-tagline">Crisis Awareness <span class="hackathon-badge">Africa Forward</span></div>
          <h3 class="card-editorial-title">Ogaal</h3>
          <p class="card-editorial-description">
            Community-driven crisis awareness platform for incident reporting, safety alerts, and verified emergency information with real-time safety maps.
          </p>
        </div>

        <div class="card-editorial" data-reveal>
          <div class="card-editorial-icon"><i data-lucide="satellite"></i></div>
          <div class="card-editorial-tagline">Disaster Warning <span class="hackathon-badge">Africa Forward</span></div>
          <h3 class="card-editorial-title">TerraSat</h3>
          <p class="card-editorial-description">
            Satellite-powered disaster early warning system combining Earth observation data, weather models, and USSD alerts to warn communities before floods strike.
          </p>
        </div>

        <div class="card-editorial" data-reveal>
          <div class="card-editorial-icon"><i data-lucide="shield-alert"></i></div>
          <div class="card-editorial-tagline">Personal Safety <span class="hackathon-badge">Africa Forward</span></div>
          <h3 class="card-editorial-title">SafePulse AI</h3>
          <p class="card-editorial-description">
            IoT wearable safety system for women and children that detects distress and automatically sends alerts, GPS location, and emergency notifications.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- 6. AI & INTELLIGENCE SUITE -->
  <section class="section section-alt">
    <div class="container">
      <div class="section-header">
        <p class="eyebrow">AI & Intelligence</p>
        <h2 class="section-title">AI-Forward, Africa-Focused</h2>
        <p class="section-description">
          Embedding intelligence across finance, healthcare, marketing, HR, and
          governance.
        </p>
      </div>

      <div class="card-grid-editorial cols-3">
        <div class="card-editorial" data-reveal>
          <div class="card-editorial-icon">
            <i data-lucide="message-square"></i>
          </div>
          <div class="card-editorial-tagline">Customer Support</div>
          <h3 class="card-editorial-title">AI Chatbot</h3>
          <p class="card-editorial-description">
            24/7 AI-powered automated customer support system deployable across
            businesses and institutions.
          </p>
        </div>

        <div class="card-editorial" data-reveal>
          <div class="card-editorial-icon">
            <i data-lucide="shield-check"></i>
          </div>
          <div class="card-editorial-tagline">Misinformation Detection</div>
          <h3 class="card-editorial-title">TruthGuard</h3>
          <p class="card-editorial-description">
            AI credibility analysis tool that scores text and screenshots for
            misinformation risk.
          </p>
        </div>

        <div class="card-editorial" data-reveal>
          <div class="card-editorial-icon"><i data-lucide="globe"></i></div>
          <div class="card-editorial-tagline">Multilingual AI</div>
          <h3 class="card-editorial-title">CommBridge AI</h3>
          <p class="card-editorial-description">
            Multilingual conversational AI platform with real-time translation
            bridging language gaps across Africa.
          </p>
        </div>

        <div class="card-editorial" data-reveal>
          <div class="card-editorial-icon">
            <i data-lucide="bar-chart-2"></i>
          </div>
          <div class="card-editorial-tagline">Social CRM</div>
          <h3 class="card-editorial-title">InsightKE</h3>
          <p class="card-editorial-description">
            AI-powered social CRM integrating Instagram, WhatsApp, and digital
            communication channels into a unified intelligence layer.
          </p>
        </div>

        <div class="card-editorial" data-reveal>
          <div class="card-editorial-icon"><i data-lucide="scan-line"></i></div>
          <div class="card-editorial-tagline">Content Authenticity</div>
          <h3 class="card-editorial-title">AI Disprover</h3>
          <p class="card-editorial-description">
            Browser extension that detects AI-generated content in real time,
            preserving information integrity.
          </p>
        </div>

        <div class="card-editorial" data-reveal>
          <div class="card-editorial-icon"><i data-lucide="megaphone"></i></div>
          <div class="card-editorial-tagline">Marketing Automation</div>
          <h3 class="card-editorial-title">Marketing Hack</h3>
          <p class="card-editorial-description">
            SME marketing automation system for WhatsApp and SMS campaigns,
            reach more customers with less effort.
          </p>
        </div>

        <div class="card-editorial" data-reveal>
          <div class="card-editorial-icon"><i data-lucide="filter"></i></div>
          <div class="card-editorial-tagline">Content Safety</div>
          <h3 class="card-editorial-title">Toxic Content Moderator</h3>
          <p class="card-editorial-description">
            AI moderation system that detects harmful content and suggests
            constructive rewrites for safer digital spaces.
          </p>
        </div>

        <!-- Africa Forward Hackathon — AI & AgriTech -->
        <div class="card-editorial" data-reveal>
          <div class="card-editorial-icon"><i data-lucide="sprout"></i></div>
          <div class="card-editorial-tagline">AgriTech Intelligence <span class="hackathon-badge">Africa Forward</span></div>
          <h3 class="card-editorial-title">AkiLimo</h3>
