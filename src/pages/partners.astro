---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Partners"
  description="The organisations, investors, and institutions that deploy, support, and grow alongside Momentum Collective across African markets."
  barbaNamespace="partners"
>
  <!-- 1. HERO -->
  <section class="hero hero-compact">
    <div class="container">
      <div class="hero-content">
        <p class="hero-eyebrow">Our Ecosystem</p>
        <h1 class="hero-title" data-split>Partners & Collaborators</h1>
        <p class="hero-subtext">
          The organisations, investors, and institutions that deploy our systems,
          fund our talent, and grow alongside the Momentum ecosystem.
        </p>
      </div>
    </div>
  </section>

  <!-- 2. PARTNER LOGOS — placeholder grid -->
  <section class="section" style="padding-top: var(--space-md);">
    <div class="container">
      <div class="section-header">
        <p class="eyebrow">Trusted By</p>
        <h2 class="section-title">Our Partners</h2>
      </div>

      <!-- Logo grid — add partner logos here -->
      <div
        style="
          display: grid;
          grid-template-columns: repeat(2, 1fr);
          gap: var(--space-sm);
        "
      >
        <!-- Partner logo placeholder — duplicate as needed -->
        <div
          style="
            border: 1px dashed var(--border-subtle);
            border-radius: 4px;
            padding: var(--space-md);
            display: flex;
            align-items: center;
            justify-content: center;
            min-height: 100px;
            color: var(--text-muted);
          "
        >
          <p style="font-family: var(--font-mono); font-size: var(--text-xs); text-transform: uppercase; letter-spacing: 0.1em; text-align: center;">
            Partner Logo
          </p>
        </div>

        <div
          style="
            border: 1px dashed var(--border-subtle);
            border-radius: 4px;
            padding: var(--space-md);
            display: flex;
            align-items: center;
            justify-content: center;
            min-height: 100px;
            color: var(--text-muted);
          "
        >
          <p style="font-family: var(--font-mono); font-size: var(--text-xs); text-transform: uppercase; letter-spacing: 0.1em; text-align: center;">
            Partner Logo
          </p>
        </div>

        <div
          style="
            border: 1px dashed var(--border-subtle);
            border-radius: 4px;
            padding: var(--space-md);
            display: flex;
            align-items: center;
            justify-content: center;
            min-height: 100px;
            color: var(--text-muted);
          "
        >
          <p style="font-family: var(--font-mono); font-size: var(--text-xs); text-transform: uppercase; letter-spacing: 0.1em; text-align: center;">
            Partner Logo
          </p>
        </div>

        <div
          style="
            border: 1px dashed var(--border-subtle);
            border-radius: 4px;
            padding: var(--space-md);
            display: flex;
            align-items: center;
            justify-content: center;
            min-height: 100px;
            color: var(--text-muted);
          "
        >
          <p style="font-family: var(--font-mono); font-size: var(--text-xs); text-transform: uppercase; letter-spacing: 0.1em; text-align: center;">
            Partner Logo
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- 3. PARTNER TYPES -->
  <section class="section section-alt">
    <div class="container">
      <div class="section-header">
        <p class="eyebrow">How We Partner</p>
        <h2 class="section-title">Partnership Models</h2>
        <p class="section-description">
          Three distinct ways organisations engage with the Momentum ecosystem.
        </p>
      </div>

      <div class="features-grid">
        <div class="feature-card" data-reveal>
          <div class="feature-icon">
            <i data-lucide="building-2"></i>
          </div>
          <h3 class="feature-title">Enterprise Clients</h3>
          <p class="feature-text">
            Organisations that license and deploy our live software systems
            across their operations.
          </p>
        </div>

        <div class="feature-card" data-reveal>
          <div class="feature-icon">
            <i data-lucide="users"></i>
          </div>
          <h3 class="feature-title">Deployment Partners</h3>
          <p class="feature-text">
            Companies that absorb our developers directly into their teams after
            cohort completion.
          </p>
        </div>

        <div class="feature-card" data-reveal>
          <div class="feature-icon">
            <i data-lucide="heart"></i>
          </div>
          <h3 class="feature-title">Foundation Supporters</h3>
          <p class="feature-text">
            Investors, grant-makers, and institutions backing the Momentum
            Foundation's talent development mission.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- 4. FEATURED PARTNERS — add partner detail cards here -->
  <section class="section">
    <div class="container">
      <div class="section-header">
        <p class="eyebrow">Featured</p>
        <h2 class="section-title">Partner Stories</h2>
        <p class="section-description">
          How our partners are leveraging Momentum systems and talent.
        </p>
      </div>

      <!-- Partner cards — add data here -->
      <div class="card-grid-editorial cols-3">
        <!-- Partner card placeholder — duplicate as needed -->
        <div
          class="card-editorial"
          style="border-style: dashed; justify-content: center; align-items: center; text-align: center; min-height: 240px;"
          data-reveal
        >
          <p style="font-family: var(--font-mono); font-size: var(--text-xs); text-transform: uppercase; letter-spacing: 0.1em; color: var(--text-muted);">
            Partner story coming soon
          </p>
        </div>

        <div
          class="card-editorial"
          style="border-style: dashed; justify-content: center; align-items: center; text-align: center; min-height: 240px;"
          data-reveal
        >
          <p style="font-family: var(--font-mono); font-size: var(--text-xs); text-transform: uppercase; letter-spacing: 0.1em; color: var(--text-muted);">
            Partner story coming soon
          </p>
        </div>

        <div
          class="card-editorial"
          style="border-style: dashed; justify-content: center; align-items: center; text-align: center; min-height: 240px;"
          data-reveal
        >
          <p style="font-family: var(--font-mono); font-size: var(--text-xs); text-transform: uppercase; letter-spacing: 0.1em; color: var(--text-muted);">
            Partner story coming soon
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- 5. BECOME A PARTNER CTA -->
  <section class="section cta-section">
    <div class="kente-decoration"></div>
    <div class="container">
      <div class="cta-content">
        <h2 class="display-3xl mb-xs">Become a Partner</h2>
        <p class="text-muted mb-md" style="font-size: var(--text-base);">
          Whether you want to deploy our systems, hire our developers, or fund
          our talent — let's build together.
        </p>
        <div class="cta-buttons">
          <a href="/contact" class="btn btn-primary btn-lg">
            <span>Get In Touch</span>
            <i data-lucide="arrow-right"></i>
          </a>
          <a href="/services" class="btn btn-outline btn-lg">
            <span>Our Services</span>
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
