---
import BaseLayout from "../layouts/BaseLayout.astro";

const partners = [
  {
    name: "Victoria Falls Regional Institute",
    sector: "Education & Research",
    icon: "graduation-cap",
    type: "Education Partner",
    image: "/assets/victoria-falls-regional-institute.jpg",
    quote: "Committed to academic excellence and community development.",
    description:
      "VFRI is a higher education and research institution committed to academic excellence and community development. Through Momentum, organisations can commission custom digital platforms for educational and research institutions, from student portals to research repositories, Learning Management Systems (LMS), administrative and enrolment portals, and institutional research databases and websites.",
    // url: "/contact?intent=partner&partner=Victoria+Falls+Regional+Institute#contact-form-section",
  },
  {
    name: "Panoramic Synergy Enterprises",
    sector: "IT Consulting & GRC",
    icon: "shield-check",
    type: "Technology Partner",
    image: "/assets/panoramic-synergy.webp",
    quote: "Trusted and Tested IT Solutions & IT GRC.",
    description:
      "PSE is a world-class IT consulting and professional services firm specialising in IT solutions and IT Governance, Risk, and Compliance. Through Momentum, clients access PSE's full range of services, digital transformation, ERP deployment, compliance frameworks, and AI-driven engagements. PSE does not operate a direct-referral programme; all engagements flow through Momentum.",
    // url: "https://panoramicsynergy.com/",
  },
  {
    name: "Hedera",
    sector: "Blockchain & Web3",
    icon: "hexagon",
    type: "Ecosystem & Tech Partner",
    image: "/assets/hedera-logo.png",
    quote: "Hello future.",
    description:
      "Hedera is the world's only public DLT network governed by known institutions, built for fast, secure, and compliant decentralised applications. Through Momentum, clients access Hedera's enterprise network and Academy programme, with developers trained to build production-grade blockchain systems. Hedera does not operate a direct-referral programme; enquire through Momentum.",
    // url: "https://hedera.com/",
  },
  {
    name: "Innovate Maritime Africa",
    sector: "Maritime & Blue Economy",
    icon: "ship",
    type: "Venture Partner",
    image: "/assets/innovate-maritime-africa.jpg",
    quote: "The 1st Maritime Venture Studio in Africa.",
    description:
      "Africa's first maritime venture studio, IMA partners with bold maritime founders to transform ideas into impactful innovations shaping the continent's blue economy. Through Momentum, clients gain access to IMA's venture-building expertise and co-development capabilities for maritime-focused technology. IMA does not operate a direct-referral programme; enquire through Momentum.",
    // url: "https://innovatemaritimeafrica.com/",
  },
  {
    name: "Cloudora",
    sector: "Cloud & DevOps",
    icon: "cloud",
    type: "Technology Partner",
    image: "/assets/cloudora-logo.png",
    quote: "Enterprise standards for reliability, uptime, and scalability.",
    description:
      "Cloudora ensures every system deployed through Momentum meets enterprise standards for reliability, uptime, and scalability. Through Momentum, clients access Cloudora's full-stack cloud engineering expertise, from architecture design to automated deployment pipelines, container orchestration and microservices, high-availability architecture and disaster recovery, and cloud cost optimisation and monitoring. Cloudora does not operate a direct-referral programme; enquire through Momentum.",
    // url: "/contact?intent=partner&partner=Cloudora#contact-form-section",
  },
];
---

<BaseLayout
  title="Partners"
  description="The organisations, investors, and institutions that deploy, support, and grow alongside Momentum Collective across African markets."
  barbaNamespace="partners"
>
  <!-- 1. HERO -->
  <section class="hero hero-compact">
    <div class="container">
      <div class="hero-content">
        <p class="hero-eyebrow">Our Ecosystem</p>
        <h1 class="hero-title">Partners & Collaborators</h1>
        <p class="hero-subtext">
          The organisations, investors, and institutions that deploy our
          systems, fund our talent, and grow alongside the Momentum ecosystem.
        </p>
      </div>
    </div>
  </section>

  <!-- 2. PARTNER LOGOS -->
  <section class="section" style="padding-top: var(--space-md);">
    <div class="container">
      <div class="section-header">
        <p class="eyebrow">Trusted By</p>
        <h2 class="section-title">Our Partners</h2>
      </div>

      <div class="partner-stagger">
        {
          partners.map((partner) => (
            <div class="partner-row">
              <div class="partner-row-brand">
                <div class="partner-logo-box">
                  {partner.image ? (
                    <img src={partner.image} alt={`${partner.name} logo`} />
                  ) : (
                    <i
                      data-lucide={partner.icon}
                      style="width: 48px; height: 48px; color: var(--accent-ochre);"
                    />
                  )}
                </div>
                <span class="partner-type">{partner.type}</span>
              </div>

              <h3 class="partner-row-title">{partner.name}</h3>

              <div class="partner-row-body">
                {partner.quote && (
                  <p class="partner-row-quote">"{partner.quote}"</p>
                )}
                <p class="partner-row-description">{partner.description}</p>
                {partner.url && (
                  <p>
                    <a
                      href={partner.url}
                      class="programme-cta"
                      target={partner.url.startsWith("http") ? "_blank" : undefined}
                      rel={partner.url.startsWith("http") ? "noopener noreferrer" : undefined}
                    >
                      {partner.url.startsWith("http") ? "Visit partner" : "Enquire via Momentum"}
                      <i data-lucide="arrow-up-right"></i>
                    </a>
                  </p>
                )}
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- 3. PARTNER TYPES -->
  <section class="section section-alt">
    <div class="container">
      <div class="section-header">
        <p class="eyebrow">How We Partner</p>
        <h2 class="section-title">Partnership Models</h2>
        <p class="section-description">
          Three distinct ways organisations engage with the Momentum ecosystem.
        </p>
      </div>

      <div class="features-grid">
        <div class="feature-card">
          <div class="feature-icon">
            <i data-lucide="building-2"></i>
          </div>
          <h3 class="feature-title">Technology Partners</h3>
          <p class="feature-text">
            Industry leaders whose platforms and expertise Momentum co-delivers
            to clients. All client engagements flow through Momentum.
          </p>
        </div>

        <div class="feature-card">
          <div class="feature-icon">
            <i data-lucide="users"></i>
          </div>
          <h3 class="feature-title">Deployment Partners</h3>
          <p class="feature-text">
            Organisations that absorb our cohort graduates directly into their
            teams, proven, production-ready engineers from day one.
          </p>
        </div>

        <div class="feature-card">
          <div class="feature-icon">
            <i data-lucide="heart"></i>
          </div>
          <h3 class="feature-title">Foundation Supporters</h3>
          <p class="feature-text">
            Investors, grant-makers, and institutions backing Momentum's mission
            to build Africa's next generation of product leaders.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- 5. BECOME A PARTNER CTA -->
  <section class="section cta-section">
    <div class="kente-decoration"></div>
    <div class="container">
      <div class="cta-content">
        <h2 class="display-3xl mb-xs">Become a Partner</h2>
        <p class="text-muted mb-md" style="font-size: var(--text-base);">
          Whether you want to deploy our systems, hire our developers, or fund
          our talent, let's build together.
        </p>
        <div class="cta-buttons">
          <a href="/contact?intent=partner#contact-form-section" class="btn btn-primary btn-lg">
            <span>Get In Touch</span>
            <i data-lucide="arrow-right"></i>
          </a>
          <a href="/services" class="btn btn-outline btn-lg">
            <span>Our Services</span>
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .partner-row-quote {
    font-family: var(--font-display);
    font-size: var(--text-base);
    font-style: italic;
    color: var(--text-primary);
    margin-bottom: var(--space-xs);
    line-height: 1.4;
  }
</style>
