---
import BaseLayout from "../layouts/BaseLayout.astro";

const partners = [
  {
    name: "Victoria Falls Regional Institute",
    sector: "Education & Research",
    icon: "graduation-cap",
    type: "Education Partner",
    image: "https://ui-avatars.com/api/?name=VFRI&background=0F172A&color=fff",
    quote: "Committed to academic excellence and community development.",
    description:
      "Victoria Falls Regional Institute is a higher education and research institution dedicated to advancing knowledge and shaping the next generation of professionals in the region. VFRI's programmes span across disciplines, combining academic rigour with practical, community-oriented outcomes. Momentum built and maintains VFRI's full digital infrastructure — from the institutional website to learning management systems serving students and faculty.",
    url: "https://www.linkedin.com/company/momentumlabsclg/",
  },
  {
    name: "Panoramic Synergy Enterprises",
    sector: "IT Consulting & GRC",
    icon: "shield-check",
    type: "Technology Partner",
    image: "https://panoramicsynergy.com/wp-content/uploads/2024/12/PSE-logo.png",
    quote: "Trusted and Tested IT Solutions & IT GRC.",
    description:
      "PSE is a world-class IT consulting and professional services company specialising in Information Technology solutions and IT Governance, Risk, and Compliance (GRC). Their expertise spans digital transformation, ERP deployment, cybersecurity frameworks, and AI integration — serving organisations across Africa that demand enterprise-grade technology delivery.",
    url: "https://www.linkedin.com/company/panoramic-synergy-enterprises/",
  },
  {
    name: "Hedera",
    sector: "Blockchain & Web3",
    icon: "hexagon",
    type: "Ecosystem & Tech Partner",
    image: "https://cryptologos.cc/logos/hedera-hbar-logo.svg?v=025",
    quote: "Hello future.",
    description:
      "Hedera is the world's only public DLT network governed by known, trusted institutions — built for performance, security, and regulatory compliance. With sub-3-second transaction finality, industry-low fees, and an energy-efficient model, Hedera powers the next generation of enterprise blockchain applications. Momentum developers are trained on Hedera's network and build production-grade systems using its Consensus Service, Token Service, and Smart Contract infrastructure.",
    url: "https://www.linkedin.com/company/hedera/",
  },
  {
    name: "Innovate Maritime Africa",
    sector: "Maritime & Blue Economy",
    icon: "ship",
    type: "Venture & Industry Partner",
    image: "https://innovatemaritimeafrica.com/wp-content/uploads/2024/12/IMA-Logo-1-66x66.jpg",
    quote: "The 1st Maritime Venture Studio in Africa.",
    description:
      "IMA partners with bold maritime founders to transform ambitious ideas into impactful ventures — co-building companies that are shaping the future of Africa's blue economy. From port operations to cargo logistics and ocean sustainability, IMA works at the frontier of maritime innovation on the continent. Momentum engineers the software layer for IMA's portfolio, bringing product execution capability to maritime startups from idea through to market launch.",
    url: "https://www.linkedin.com/company/innovate-maritime-africa/",
  },
];
---

<BaseLayout
  title="Partners | Momentum Collective"
  description="The organisations, investors, and institutions that deploy, support, and grow alongside Momentum Collective across African markets."
  barbaNamespace="partners"
>
  <!-- 1. HERO -->
  <section class="hero hero-compact">
    <div class="container">
      <div class="hero-content">
        <p class="hero-eyebrow">Our Ecosystem</p>
        <h1 class="hero-title">Partners & Collaborators</h1>
        <p class="hero-subtext">
          The organisations, investors, and institutions that deploy our systems,
          fund our talent, and grow alongside the Momentum ecosystem.
        </p>
      </div>
    </div>
  </section>

  <!-- 2. PARTNER LOGOS -->
  <section class="section" style="padding-top: var(--space-md);">
    <div class="container">
      <div class="section-header">
        <p class="eyebrow">Trusted By</p>
        <h2 class="section-title">Our Partners</h2>
      </div>

      <div class="partner-stagger">
      {partners.map((partner, index) => (
        <div class="partner-row" data-reveal>
          <div class="partner-row-number">{(index + 1).toString().padStart(2, '0')}</div>
          
          <div class="partner-row-brand">
            <div class="partner-logo-box">
              {partner.image ? (
                <img src={partner.image} alt={`${partner.name} logo`} />
              ) : (
                <i data-lucide={partner.icon} style="width: 48px; height: 48px; color: var(--accent-ochre);"></i>
              )}
            </div>
            <span class="partner-type">{partner.type}</span>
          </div>
          
          <div class="partner-row-content">
            <h3 class="partner-row-title">{partner.name}</h3>
            {partner.quote && (
              <p class="partner-row-quote">"{partner.quote}"</p>
            )}
            <p class="partner-row-description">{partner.description}</p>
            {partner.url && partner.url !== "#" && (
              <a href={partner.url} target="_blank" rel="noopener noreferrer" class="partner-row-link">
                Visit website <i data-lucide="arrow-up-right" style="width:14px;height:14px;display:inline-block;vertical-align:middle;margin-left:4px;"></i>
              </a>
            )}
          </div>
        </div>
      ))}
    </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 3. PARTNER TYPES -->
  <section class="section section-alt">
    <div class="container">
      <div class="section-header">
        <p class="eyebrow">How We Partner</p>
        <h2 class="section-title">Partnership Models</h2>
        <p class="section-description">
          Three distinct ways organisations engage with the Momentum ecosystem.
        </p>
      </div>

      <div class="features-grid">
        <div class="feature-card" data-reveal>
          <div class="feature-icon">
            <i data-lucide="building-2"></i>
          </div>
          <h3 class="feature-title">Technology Partners</h3>
          <p class="feature-text">
            Industry leaders whose platforms and expertise Momentum co-delivers
            to clients. All client engagements flow through Momentum.
          </p>
        </div>

        <div class="feature-card" data-reveal>
          <div class="feature-icon">
            <i data-lucide="users"></i>
          </div>
          <h3 class="feature-title">Deployment Partners</h3>
          <p class="feature-text">
            Organisations that absorb our cohort graduates directly into their
            teams — proven, production-ready engineers from day one.
          </p>
        </div>

        <div class="feature-card" data-reveal>
          <div class="feature-icon">
            <i data-lucide="heart"></i>
          </div>
          <h3 class="feature-title">Foundation Supporters</h3>
          <p class="feature-text">
            Investors, grant-makers, and institutions backing Momentum's mission
            to build Africa's next generation of product leaders.
          </p>
        </div>
      </div>
    </div>
  </section>



  <!-- 5. BECOME A PARTNER CTA -->
  <section class="section cta-section">
    <div class="kente-decoration"></div>
    <div class="container">
      <div class="cta-content">
        <h2 class="display-3xl mb-xs">Become a Partner</h2>
        <p class="text-muted mb-md" style="font-size: var(--text-base);">
          Whether you want to deploy our systems, hire our developers, or fund
          our talent — let's build together.
        </p>
        <div class="cta-buttons">
          <a href="/contact" class="btn btn-primary btn-lg">
            <span>Get In Touch</span>
            <i data-lucide="arrow-right"></i>
          </a>
          <a href="/services" class="btn btn-outline btn-lg">
            <span>Our Services</span>
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .partner-logo-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-sm);
    margin-top: var(--space-md);
  }

  @media (max-width: 768px) {
    .partner-logo-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .partner-logo-card {
    border: 1px solid var(--border-subtle);
    border-radius: 8px;
    padding: var(--space-md);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    gap: var(--space-xs);
    background: var(--surface);
    transition: border-color 0.2s ease, transform 0.2s ease;
  }

  .partner-logo-card:hover {
    border-color: var(--accent-ochre);
    transform: translateY(-2px);
  }

  .partner-logo-icon {
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--accent-ochre);
    margin-bottom: calc(var(--space-xs) / 2);
  }

  .partner-logo-icon svg {
    width: 28px;
    height: 28px;
  }

  .partner-logo-name {
    font-family: var(--font-display);
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--text-primary);
    letter-spacing: 0.02em;
  }

  .partner-logo-sector {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .partner-card-sector {
    margin-top: auto;
    padding-top: var(--space-sm);
  }

  .partner-card-sector span {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--accent-ochre);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    border: 1px solid var(--accent-ochre);
    padding: 2px 8px;
    border-radius: 2px;
  }

  .partner-row-quote {
    font-family: var(--font-display);
    font-size: var(--text-base);
    font-style: italic;
    color: var(--accent-ochre);
    margin-bottom: var(--space-xs);
    line-height: 1.4;
  }

  .partner-row-link {
    display: inline-flex;
    align-items: center;
    margin-top: var(--space-xs);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-muted);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .partner-row-link:hover {
    color: var(--accent-ochre);
  }

  .partner-logo-box img {
    max-width: 80px;
    max-height: 60px;
    object-fit: contain;
    filter: grayscale(30%);
    transition: filter 0.2s ease;
  }

  .partner-row:hover .partner-logo-box img {
    filter: grayscale(0%);
  }
</style>
