---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Services | Momentum Collective" description="Discover our services." barbaNamespace="services">

  <!-- 1. PAGE HERO -->
  <section class="hero">
    <div class="container">
      <div class="hero-content">
        <p class="hero-eyebrow">Why Partner With Us</p>
        <h1 class="hero-title display-5xl" data-split>
          Youth-Driven, Africa-First
        </h1>
        <p class="hero-subtext">
          We are a dynamic collective of young African developers, designers, and innovators delivering technology solutions rooted in local context and built for global impact.
        </p>
        <div class="hero-buttons">
          <a href="/contact" class="btn btn-primary btn-lg">
            <span>Start a Project</span>
            <i data-lucide="arrow-right"></i>
          </a>
          <a href="/apps" class="btn btn-outline btn-lg">
            <span>See Our Work</span>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- 2. SERVICES GRID -->
  <section class="section section-alt">
    <div class="container">
      <h2 class="display-4xl mb-lg" data-split>Our Advantages</h2>
      <div class="grid-3">

        <div class="service-card" data-reveal>
          <span class="service-number">01</span>
          <div class="service-icon">
            <i data-lucide="users"></i>
          </div>
          <div class="service-content">
            <h3>Youth-Driven Innovation</h3>
            <p>Powered by talented African youth who understand local needs and global standards.</p>
          </div>
        </div>

        <div class="service-card" data-reveal>
          <span class="service-number">02</span>
          <div class="service-icon">
            <i data-lucide="dollar-sign"></i>
          </div>
          <div class="service-content">
            <h3>Cost-Effective Solutions</h3>
            <p>Affordable, high-value technology designed for the African market.</p>
          </div>
        </div>

        <div class="service-card" data-reveal>
          <span class="service-number">03</span>
          <div class="service-icon">
            <i data-lucide="heart"></i>
          </div>
          <div class="service-content">
            <h3>Community-Centric</h3>
            <p>Built with a deep understanding of African cultures, values, and community needs.</p>
          </div>
        </div>

        <div class="service-card" data-reveal>
          <span class="service-number">04</span>
          <div class="service-icon">
            <i data-lucide="headphones"></i>
          </div>
          <div class="service-content">
            <h3>Ongoing Support</h3>
            <p>Continuous support and updates to ensure your solutions evolve with your business.</p>
          </div>
        </div>

        <div class="service-card" data-reveal>
          <span class="service-number">05</span>
          <div class="service-icon">
            <i data-lucide="globe"></i>
          </div>
          <div class="service-content">
            <h3>Pan-African Context</h3>
            <p>Built for the diverse and dynamic African business environment.</p>
          </div>
        </div>

        <div class="service-card" data-reveal>
          <span class="service-number">06</span>
          <div class="service-icon">
            <i data-lucide="scale"></i>
          </div>
          <div class="service-content">
            <h3>Inclusive Design</h3>
            <p>Gender-sensitive platforms that create opportunities for all community members.</p>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- 3. HOW WE WORK -->
  <section class="section">
    <div class="container">
      <p class="eyebrow">Our Process</p>
      <h2 class="display-4xl mb-lg" data-split>How We Work</h2>
      <div class="process-grid">

        <div class="process-step" data-reveal>
          <div class="process-icon">
            <i data-lucide="search"></i>
          </div>
          <h3 class="process-title">Discover</h3>
          <p class="process-description">We deeply understand your context, users, and business environment.</p>
        </div>

        <div class="process-step" data-reveal>
          <div class="process-icon">
            <i data-lucide="layers"></i>
          </div>
          <h3 class="process-title">Design & Build</h3>
          <p class="process-description">Rapid prototyping and iterative development grounded in African design principles.</p>
        </div>

        <div class="process-step" data-reveal>
          <div class="process-icon">
            <i data-lucide="rocket"></i>
          </div>
          <h3 class="process-title">Launch & Scale</h3>
          <p class="process-description">We launch with you and scale continuously based on real user feedback.</p>
        </div>

      </div>
    </div>
  </section>

  <!-- 4. CTA -->
  <section class="section cta-section">
    <div class="kente-decoration"></div>
    <div class="container">
      <div class="cta-content">
        <h2 class="display-4xl mb-sm">Ready to Partner?</h2>
        <p class="text-muted mb-md">
          Let us help you build technology that serves your community, scales across the continent, and stands out on the global stage.
        </p>
        <div class="cta-buttons">
          <a href="/contact" class="btn btn-primary btn-lg">
            <span>Get In Touch</span>
            <i data-lucide="arrow-right"></i>
          </a>
          <a href="/apps" class="btn btn-outline btn-lg">
            <span>Explore Products</span>
          </a>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<script>
  import { initMarquee } from '../scripts/marquee';
</script>
