---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Services | Momentum Collective"
  description="Partner with Momentum Labs CLG, execution-first development, dedicated product teams, 6-8 week intensive cohorts, and AI-forward solutions built for African markets."
  barbaNamespace="services"
>
  <!-- 1. PAGE HERO -->
  <section class="hero">
    <div class="container">
      <div class="hero-content">
        <p class="hero-eyebrow">Why Partner With Momentum</p>
        <h1 class="hero-title" data-split>Execution Over Theory</h1>
        <p class="hero-subtext">
          We don't ship GitHub repositories, we ship live products. Our teams
          build, iterate, and scale real software into African markets through
          focused 6-8 week cycles.
        </p>
        <div class="hero-buttons">
          <a href="/contact" class="btn btn-primary btn-lg">
            <span>Start a Partnership</span>
            <i data-lucide="arrow-right"></i>
          </a>
          <a href="/apps" class="btn btn-outline btn-lg">
            <span>See Our Products</span>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- 2. OUR EDGE -->
  <section class="section section-alt">
    <div class="container">
      <div class="section-header">
        <p class="eyebrow">Our Edge</p>
        <h2 class="display-3xl mb-xs" data-split>What Sets Us Apart</h2>
        <p class="text-muted" style="max-width: 600px; margin: 0 auto;">
          Five principles that define how we build, who we build for, and why
          our products survive in the market.
        </p>
      </div>

      <div class="card-grid-editorial cols-3">
        <div class="card-editorial" data-reveal>
          <div class="card-editorial-icon">
            <i data-lucide="rocket"></i>
          </div>
          <div class="card-editorial-tagline">Edge 01</div>
          <h3 class="card-editorial-title">Execution Over Theory</h3>
          <p class="card-editorial-description">
            We ship live products, not just GitHub repositories. Every developer
            who passes through Momentum has shipped code to production clients.
          </p>
        </div>

        <div class="card-editorial" data-reveal>
          <div class="card-editorial-icon">
            <i data-lucide="users"></i>
          </div>
          <div class="card-editorial-tagline">Edge 02</div>
          <h3 class="card-editorial-title">Dedicated Product Teams</h3>
          <p class="card-editorial-description">
            Each software system has committed developers actively maintaining
            and scaling it. You're not getting a one-time build, you're getting
            a team.
          </p>
        </div>

        <div class="card-editorial" data-reveal>
          <div class="card-editorial-icon">
            <i data-lucide="zap"></i>
          </div>
          <div class="card-editorial-tagline">Edge 03</div>
          <h3 class="card-editorial-title">Short, Intensive Cycles</h3>
          <p class="card-editorial-description">
            6-8 weeks of structured, real-world development. No bloated
            timelines. Momentum operates on discipline and delivery, features
            ship on schedule.
          </p>
        </div>

        <div class="card-editorial" data-reveal>
          <div class="card-editorial-icon">
            <i data-lucide="globe"></i>
          </div>
          <div class="card-editorial-tagline">Edge 04</div>
          <h3 class="card-editorial-title">Market-Focused Innovation</h3>
          <p class="card-editorial-description">
            Every product addresses real operational inefficiencies in African
            markets, from healthcare and finance to retail, property, and
            education.
          </p>
        </div>

        <div class="card-editorial" data-reveal>
          <div class="card-editorial-icon">
            <i data-lucide="bot"></i>
          </div>
          <div class="card-editorial-tagline">Edge 05</div>
          <h3 class="card-editorial-title">AI-Forward Strategy</h3>
          <p class="card-editorial-description">
            We are embedding AI across sectors, finance, healthcare, marketing,
            HR, and governance. Every product line has an intelligence layer in
            development.
          </p>
        </div>

        <div class="card-editorial" data-reveal>
          <div class="card-editorial-icon">
            <i data-lucide="user-plus"></i>
          </div>
          <div class="card-editorial-tagline">Edge 06</div>
          <h3 class="card-editorial-title">Built-In Talent Pipeline</h3>
          <p class="card-editorial-description">
            Partner companies gain access to Momentum-trained developers,
            engineers who have shipped production software, worked in agile
            teams, and understand commercial systems.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- 3. REVENUE MODEL -->
  <section class="section">
    <div class="container">
      <div class="section-header">
        <p class="eyebrow">How We Go to Market</p>
        <h2 class="section-title">Our Revenue Model</h2>
        <p class="section-description">
          All systems are sold externally to businesses, institutions, and
          organisations across Africa. Developers contribute directly to
          monetized products.
        </p>
      </div>

      <div class="process-grid">
        <div class="process-step" data-reveal>
          <div class="process-icon">
            <i data-lucide="layers"></i>
          </div>
          <h3 class="process-title">SaaS Subscriptions</h3>
          <p class="process-description">
            Recurring monthly access to our platforms for businesses and
            institutions.
          </p>
        </div>

        <div class="process-step" data-reveal>
          <div class="process-icon">
            <i data-lucide="shield"></i>
          </div>
          <h3 class="process-title">Enterprise Licensing</h3>
          <p class="process-description">
            White-label and custom deployment for large organisations requiring
            dedicated infrastructure.
          </p>
        </div>

        <div class="process-step" data-reveal>
          <div class="process-icon">
            <i data-lucide="code-2"></i>
          </div>
          <h3 class="process-title">Custom Development</h3>
          <p class="process-description">
            Bespoke software built by Momentum teams, from concept to production
            deployment.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- 4. HOW WE WORK -->
  <section class="section section-alt">
    <div class="container">
      <div class="section-header">
        <p class="eyebrow">The Cohort Process</p>
        <h2 class="section-title">How a Partnership Works</h2>
      </div>
      <div class="process-grid">
        <div class="process-step" data-reveal>
          <div class="process-icon">
            <i data-lucide="search"></i>
          </div>
          <h3 class="process-title">Discover</h3>
          <p class="process-description">
            We map your context, operational gaps, and product-market fit. No
            assumptions, deep discovery first.
          </p>
        </div>

        <div class="process-step" data-reveal>
          <div class="process-icon">
            <i data-lucide="layers"></i>
          </div>
          <h3 class="process-title">Build & Ship</h3>
          <p class="process-description">
            A dedicated cohort team works in focused 6-8 week cycles, shipping
            iteratively into production environments.
          </p>
        </div>

        <div class="process-step" data-reveal>
          <div class="process-icon">
            <i data-lucide="rocket"></i>
          </div>
          <h3 class="process-title">Scale & Maintain</h3>
          <p class="process-description">
            A committed team stays on the product post-launch, iterating,
            scaling, and evolving based on live user data.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- 5. CTA -->
  <section class="section cta-section">
    <div class="kente-decoration"></div>
    <div class="container">
      <div class="cta-content">
        <h2 class="display-4xl mb-sm">Ready to Partner?</h2>
        <p class="text-muted mb-md">
          Deploy one of our 23+ live systems into your organisation, license our
          technology, or build something entirely new with a Momentum product
          team.
        </p>
        <div class="cta-buttons">
          <a href="/contact" class="btn btn-primary btn-lg">
            <span>Get In Touch</span>
            <i data-lucide="arrow-right"></i>
          </a>
          <a href="/apps" class="btn btn-outline btn-lg">
            <span>Explore Products</span>
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  import { initMarquee } from "../scripts/marquee";
</script>
