---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Services - Momentum Collective" description="Discover the services offered by Momentum Collective, from youth-driven innovation to community-centric solutions.">
    <!-- Services Section -->
    <section id="services" class="services">
        <div class="container">
            <h2 class="section-title">Why Partner with <span class="highlight">Momentum Collective</span>?</h2>
            <div class="services-grid">
                <div class="service-card">
                    <div class="service-icon">
                        <i class="fas fa-users"></i>
                    </div>
                    <h3>Youth-Driven Innovation</h3>
                    <p>Powered by talented African youth who understand local needs and global standards.</p>
                </div>

                <div class="service-card">
                    <div class="service-icon">
                        <i class="fas fa-dollar-sign"></i>
                    </div>
                    <h3>Cost-Effective Solutions</h3>
                    <p>Affordable, high-value technology designed for the African market.</p>
                </div>

                <div class="service-card">
                    <div class="service-icon">
                        <i class="fas fa-heart"></i>
                    </div>
                    <h3>Community-Centric</h3>
                    <p>Built with a deep understanding of African cultures, values, and community needs.</p>
                </div>

                <div class="service-card">
                    <div class="service-icon">
                        <i class="fas fa-headset"></i>
                    </div>
                    <h3>Ongoing Support</h3>
                    <p>Continuous support and updates to ensure your solutions evolve with your business.</p>
                </div>

                <div class="service-card">
                    <div class="service-icon">
                        <i class="fas fa-globe-africa"></i>
                    </div>
                    <h3>Pan-African Context</h3>
                    <p>Built for the diverse and dynamic African business environment.</p>
                </div>

                <div class="service-card">
                    <div class="service-icon">
                        <i class="fas fa-balance-scale"></i>
                    </div>
                    <h3>Inclusive Design</h3>
                    <p>Gender-sensitive platforms that create opportunities for all community members.</p>
                </div>
            </div>
        </div>
    </section>
</BaseLayout>
