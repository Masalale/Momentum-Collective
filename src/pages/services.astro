---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Services"
  description="Momentum Labs CLG runs Africa's most intensive developer programmes: cohorts, masterclasses, and hackathons, and provides exclusive access to best-in-class technology partners."
  barbaNamespace="services"
>
  <!-- 1. PAGE HERO -->
  <section class="hero">
    <div class="container">
      <div class="hero-content">
        <p class="hero-eyebrow">What We Do</p>
        <h1 class="hero-title">Execution Over Theory</h1>
        <p class="hero-subtext">
          We run Africa's most intensive developer programmes: cohorts,
          masterclasses, and hackathons. We also connect clients with
          world-class technology partners across blockchain, IT consulting,
          maritime, education, and cloud infrastructure.
        </p>
        <div class="hero-buttons">
          <a href="/contact?intent=general#contact-form-section" class="btn btn-primary btn-lg">
            <span>Start a Conversation</span>
            <i data-lucide="arrow-right"></i>
          </a>
          <a href="/apps" class="btn btn-outline btn-lg">
            <span>See Our Products</span>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- 2. CORE PROGRAMMES -->
  <section id="core-programs" class="section section-alt">
    <div class="container">
      <div class="section-header">
        <p class="eyebrow">Core Programmes</p>
        <h2 class="section-title">How We Train Builders</h2>
        <p class="section-description">
          High-intensity formats designed for one outcome: developers who ship
          real software into production.
        </p>
      </div>

      <div class="card-grid-editorial">
        <!-- Cohorts -->
        <div
          id="cohorts"
          class="card-editorial card-editorial--programme"
                 >
          <div class="card-editorial-icon"><i data-lucide="users"></i></div>
          <div class="card-editorial-tagline">
            Intensive Programme · 6–8 Weeks
          </div>
          <h3 class="card-editorial-title">Cohorts</h3>
          <p class="card-editorial-description">
            Our flagship format. Developers join live product teams, ship
            production software, and emerge as engineers who've proven
            themselves in real market conditions, not just in theory.
          </p>
          <ul class="programme-list">
            <li>
              <i data-lucide="check-circle-2"></i> Join a live product team from day
              one
            </li>
            <li>
              <i data-lucide="check-circle-2"></i> Ship to production within the first
              8 weeks
            </li>
            <li>
              <i data-lucide="check-circle-2"></i> Mentored by senior engineers throughout
            </li>
            <li>
              <i data-lucide="check-circle-2"></i> Graduate with a portfolio of deployed
              software
            </li>
          </ul>
          <a href="/contact?service=cohorts&intent=developer#contact-form-section" class="programme-cta">
            Enquire about cohorts <i data-lucide="arrow-right"></i>
          </a>
        </div>

        <!-- Masterclasses + Hackathons -->
        <div
          id="masterclasses"
          class="card-editorial card-editorial--programme"
                 >
          <div class="card-editorial-icon"><i data-lucide="book-open"></i></div>
          <div class="card-editorial-tagline">
            Specialist Sessions & Hackathons
          </div>
          <h3 class="card-editorial-title">Masterclasses</h3>
          <p class="card-editorial-description">
            Targeted deep-dives into specific stacks, tools, and disciplines.
            Delivered by practitioners actively using these technologies in
            production, not instructors reading from slides.
          </p>
          <div class="programme-sub-section">
            <p class="card-editorial-tagline" style="margin-bottom: 0.5rem;">
              Hackathon Events · 1 Week
            </p>
            <p
              class="card-editorial-description"
              style="margin-bottom: 0.5rem;"
            >
              Plus high-energy build events where developers tackle real
              problems and ship working prototypes in days, used to surface
              talent, test ideas fast, and generate proof-of-concept systems.
            </p>
            <ul class="programme-list">
              <li>
                <i data-lucide="check-circle-2"></i> Organisation-sponsored problem
                statements
              </li>
              <li>
                <i data-lucide="check-circle-2"></i> Cross-functional developer teams
              </li>
              <li>
                <i data-lucide="check-circle-2"></i> Working demos at the end, not
                slide decks
              </li>
              <li>
                <i data-lucide="check-circle-2"></i> Best projects fast-tracked into
                full builds
              </li>
            </ul>
          </div>

          <a href="/contact?service=masterclasses&intent=learn#contact-form-section" class="programme-cta">
            Enquire about masterclasses & hackathons <i
              data-lucide="arrow-right"></i>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- 3. INTENT SELECTOR -->
  <section
    class="section"
    style="padding-top: var(--space-md); padding-bottom: var(--space-md);"
  >
    <div class="container">
      <div class="section-header" style="margin-bottom: var(--space-md);">
        <p class="eyebrow">Where to Start</p>
        <h2 class="section-title">What brings you here?</h2>
        <p class="section-description">
          Select your intent and we'll show you exactly what applies.
        </p>
      </div>

      <div class="intent-grid">
        <button
          class="intent-card"
          data-intent="developer"
          data-scroll="cohorts"
          data-subject="Developer Cohort Application"
          data-body="Hi Momentum, I'm a developer interested in joining your next cohort to ship real software."
        >
          <div class="intent-icon"><i data-lucide="code-2"></i></div>
          <div class="intent-label">I'm a developer</div>
          <div class="intent-hint">Join a cohort</div>
        </button>

        <button
          class="intent-card"
          data-intent="train"
          data-scroll="masterclasses"
          data-subject="Masterclass & Hackathon Enquiry"
          data-body="Hi Momentum, I'm interested in your masterclasses and hackathon events."
        >
          <div class="intent-icon"><i data-lucide="graduation-cap"></i></div>
          <div class="intent-label">Learn with us</div>
          <div class="intent-hint">Masterclasses & hackathons</div>
        </button>

        <a href="/courses" class="intent-card intent-card--link">
          <div class="intent-icon"><i data-lucide="book-open"></i></div>
          <div class="intent-label">Browse courses</div>
          <div class="intent-hint">Partner learning</div>
        </a>

        <button
          class="intent-card"
          data-intent="partner"
          data-subject="Company Partnership Enquiry"
          data-body="Hi Momentum, we're a company interested in partnering with Momentum Collective."
        >
          <div class="intent-icon"><i data-lucide="handshake"></i></div>
          <div class="intent-label">Partner with us</div>
          <div class="intent-hint">For companies</div>
        </button>
      </div>
    </div>
  </section>

  <!-- 4. CTA SECTION -->
  <section class="section cta-section" style="margin-top: var(--space-xl);">
    <div class="kente-decoration"></div>
    <div class="container container-narrow text-center">
      <h2 class="display-3xl" style="margin-bottom: var(--space-sm);">
        Partner With the Lab
      </h2>
      <p class="text-lg text-muted" style="margin-bottom: var(--space-lg);">
        Whether you want to train your team, run a hackathon, or access a
        technology partner, start a conversation with Momentum.
      </p>
      <div class="flex items-center justify-center gap-sm">
        <a href="/contact?intent=general#contact-form-section" class="btn btn-primary btn-lg">
          <span>Start a Conversation</span><i data-lucide="arrow-right"></i>
        </a>
        <a href="/apps" class="btn btn-outline btn-lg"> See Our Products </a>
      </div>
    </div>
  </section>

  <!-- INTENT STICKY BAR -->
  <div id="intent-sticky" class="intent-sticky" aria-hidden="true">
    <div class="intent-sticky-inner">
      <span class="intent-sticky-label" id="intent-sticky-label"
        >Ready to get started?</span
      >
      <a id="intent-sticky-cta" href="/contact#contact-form-section" class="btn btn-primary">
        <span id="intent-sticky-cta-text">Book a call</span>
        <i data-lucide="arrow-up-right" style="width:16px;height:16px;"></i>
      </a>
      <button
        class="intent-sticky-close"
        id="intent-sticky-close"
        aria-label="Dismiss"
      >
        <i data-lucide="x" style="width:16px;height:16px;"></i>
      </button>
    </div>
  </div>
</BaseLayout>
