---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Services | Momentum Collective"
  description="Discover our services."
  barbaNamespace="services"
>
  <!-- 1. PAGE HERO -->
  <section class="hero">
    <div class="container">
      <div class="hero-content">
        <p class="hero-eyebrow">Why Partner With Us</p>
        <h1 class="hero-title" data-split>Youth-Driven, Africa-First</h1>
        <p class="hero-subtext">
          We are a dynamic collective of young African developers, designers,
          and innovators delivering technology solutions rooted in local context
          and built for global impact.
        </p>
        <div class="hero-buttons">
          <a href="/contact" class="btn btn-primary btn-lg">
            <span>Start a Project</span>
            <i data-lucide="arrow-right"></i>
          </a>
          <a href="/apps" class="btn btn-outline btn-lg">
            <span>See Our Work</span>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- 2. OUR ADVANTAGES -->
  <section class="section section-alt">
    <div class="container">
      <div class="section-header">
        <p class="eyebrow">Momentum Advantage</p>
        <h2 class="display-3xl mb-xs" data-split>Why Partner With Us</h2>
        <p class="text-muted" style="max-width: 600px; margin: 0 auto;">
          Delivering technology solutions rooted in local context and built for
          global impact.
        </p>
      </div>

      <div class="card-grid-editorial cols-3">
        <div class="card-editorial" data-reveal>
          <div class="card-editorial-icon">
            <i data-lucide="users"></i>
          </div>
          <div class="card-editorial-tagline">Advantage 01</div>
          <h3 class="card-editorial-title">Youth-Driven Innovation</h3>
          <p class="card-editorial-description">
            Powered by talented African youth who understand local needs and
            global standards.
          </p>
        </div>

        <div class="card-editorial" data-reveal>
          <div class="card-editorial-icon">
            <i data-lucide="dollar-sign"></i>
          </div>
          <div class="card-editorial-tagline">Advantage 02</div>
          <h3 class="card-editorial-title">Cost-Effective Solutions</h3>
          <p class="card-editorial-description">
            Affordable, high-value technology specifically designed for the
            African market.
          </p>
        </div>

        <div class="card-editorial" data-reveal>
          <div class="card-editorial-icon">
            <i data-lucide="heart"></i>
          </div>
          <div class="card-editorial-tagline">Advantage 03</div>
          <h3 class="card-editorial-title">Community-Centric</h3>
          <p class="card-editorial-description">
            Built with a deep understanding of African cultures, values, and
            community needs.
          </p>
        </div>

        <div class="card-editorial" data-reveal>
          <div class="card-editorial-icon">
            <i data-lucide="headphones"></i>
          </div>
          <div class="card-editorial-tagline">Advantage 04</div>
          <h3 class="card-editorial-title">Ongoing Support</h3>
          <p class="card-editorial-description">
            Continuous updates to ensure your solutions evolve with your
            business.
          </p>
        </div>

        <div class="card-editorial" data-reveal>
          <div class="card-editorial-icon">
            <i data-lucide="globe"></i>
          </div>
          <div class="card-editorial-tagline">Advantage 05</div>
          <h3 class="card-editorial-title">Pan-African Context</h3>
          <p class="card-editorial-description">
            Built for the diverse and dynamic African business environment.
          </p>
        </div>

        <div class="card-editorial" data-reveal>
          <div class="card-editorial-icon">
            <i data-lucide="scale"></i>
          </div>
          <div class="card-editorial-tagline">Advantage 06</div>
          <h3 class="card-editorial-title">Inclusive Design</h3>
          <p class="card-editorial-description">
            Gender-sensitive platforms that create opportunities for all
            community members.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- 3. HOW WE WORK -->
  <section class="section">
    <div class="container">
      <div class="section-header">
        <p class="eyebrow">Our Process</p>
        <h2 class="section-title">How We Work</h2>
      </div>
      <div class="process-grid">
        <div class="process-step" data-reveal>
          <div class="process-icon">
            <i data-lucide="search"></i>
          </div>
          <h3 class="process-title">Discover</h3>
          <p class="process-description">
            We deeply understand your context, users, and business environment.
          </p>
        </div>

        <div class="process-step" data-reveal>
          <div class="process-icon">
            <i data-lucide="layers"></i>
          </div>
          <h3 class="process-title">Design & Build</h3>
          <p class="process-description">
            Rapid prototyping and iterative development grounded in African
            design principles.
          </p>
        </div>

        <div class="process-step" data-reveal>
          <div class="process-icon">
            <i data-lucide="rocket"></i>
          </div>
          <h3 class="process-title">Launch & Scale</h3>
          <p class="process-description">
            We launch with you and scale continuously based on real user
            feedback.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- 4. CTA -->
  <section class="section cta-section">
    <div class="kente-decoration"></div>
    <div class="container">
      <div class="cta-content">
        <h2 class="display-4xl mb-sm">Ready to Partner?</h2>
        <p class="text-muted mb-md">
          Let us help you build technology that serves your community, scales
          across the continent, and stands out on the global stage.
        </p>
        <div class="cta-buttons">
          <a href="/contact" class="btn btn-primary btn-lg">
            <span>Get In Touch</span>
            <i data-lucide="arrow-right"></i>
          </a>
          <a href="/apps" class="btn btn-outline btn-lg">
            <span>Explore Products</span>
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  import { initMarquee } from "../scripts/marquee";
</script>
