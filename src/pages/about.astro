---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="About | Momentum Collective"
  description="Momentum Labs CLG, Africa's execution-first product lab. We bridge the gap between technical training and commercial execution through 6-8 week intensive cohorts."
  barbaNamespace="about"
>
  <!-- 1. ABOUT HERO - split layout requested by user -->
  <section class="hero">
    <div class="container">
      <div class="about-hero-grid">
        <div class="about-hero-copy">
          <p class="hero-eyebrow">About Momentum Labs CLG</p>
          <h1 class="hero-title">From Ivy to Momentum</h1>
          <p class="hero-subtext">
            We evolved from Ivy Community, a growing network of ambitious young
            developers across Kenya, into a structured, execution-driven product
            lab where developers don't just learn to code. They learn to build
            businesses.
          </p>
          <div class="hero-buttons about-hero-buttons">
            <a href="/contact" class="btn btn-primary btn-lg">
              <span>Join the Cohort</span>
              <i data-lucide="arrow-right"></i>
            </a>
            <a href="/apps" class="btn btn-outline btn-lg">
              <span>Explore Our Products</span>
            </a>
          </div>
        </div>

        <div class="about-hero-visual" data-reveal>
          <div class="hero-logo-container">
            <img
              src="/assets/ivy_momentum.png"
              alt="From Ivy to Momentum"
              class="hero-logo"
              loading="eager"
            />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 2. VISION / MISSION -->
  <section class="section section-alt">
    <div class="container">
      <div class="grid-2">
        <div data-reveal>
          <p class="eyebrow">Our Vision</p>
          <div class="card-icon mb-sm">
            <i data-lucide="eye"></i>
          </div>
          <h5>
            To build Africa's most execution-focused developer ecosystem, where
            young engineers transition from learners to builders, and from
            builders to product leaders.
          </h5>
          <p class="eyebrow" style="margin-top: 1.5rem;">
            "Our Ideas, Our Future."
          </p>
        </div>
        <div data-reveal>
          <p class="eyebrow">Our Mission</p>
          <div class="card-icon mb-sm">
            <i data-lucide="target"></i>
          </div>
          <h5>
            To bridge the gap between technical training and commercial
            execution, placing developers inside live product teams that build,
            sell, and scale real software across African markets.
          </h5>
        </div>
      </div>
    </div>
  </section>

  <!-- 3. THE COHORT MODEL -->
  <section class="section">
    <div class="container">
      <div class="section-header">
        <p class="eyebrow">Our Model</p>
        <h2 class="section-title">The 6-8 Week Cohort</h2>
        <p class="section-description">
          Momentum runs structured intensive cohorts. Each cycle places
          developers inside live product teams working on real, commercially
          active software.
        </p>
      </div>

      <div class="features-grid">
        <div class="feature-card" data-reveal>
          <div class="feature-icon">
            <i data-lucide="users"></i>
          </div>
          <h3 class="feature-title">Onboard & Orient</h3>
          <p class="feature-text">
            Week 1-2: Join an active product team, understand the codebase, and
            get oriented on client requirements and delivery standards.
          </p>
        </div>

        <div class="feature-card" data-reveal>
          <div class="feature-icon">
            <i data-lucide="code-2"></i>
          </div>
          <h3 class="feature-title">Build & Ship</h3>
          <p class="feature-text">
            Week 3-6: Work on real client-facing features, ship to production,
            improve performance, and participate in hackathons and
            masterclasses.
          </p>
        </div>

        <div class="feature-card" data-reveal>
          <div class="feature-icon">
            <i data-lucide="rocket"></i>
          </div>
          <h3 class="feature-title">Scale & Transition</h3>
          <p class="feature-text">
            Week 7-8: Top performers are absorbed into internal product teams.
            Others are deployed to partner companies, career-ready and
            commercially proven.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- 4. ECOSYSTEM PILLARS -->
  <section class="section section-alt">
    <div class="container">
      <div class="section-header">
        <p class="eyebrow">Our Ecosystem</p>
        <h2 class="section-title">Two Interconnected Pillars</h2>
      </div>

      <div class="features-grid" style="align-items: stretch;">
        <!-- Momentum Labs Pillar -->
        <a href="/apps" class="feature-card" data-reveal style="text-decoration: none; color: inherit; display: flex; flex-direction: column; padding: 0; overflow: hidden;">
          <div style="width: 100%; aspect-ratio: 1; background: var(--bg-alt); display: flex; align-items: center; justify-content: center; padding: var(--space-lg); border-bottom: 1px solid var(--border-subtle);">
            <img src="/assets/momentum-labs.png" alt="Momentum Labs" style="max-width: 80%; max-height: 80%; object-fit: contain; filter: drop-shadow(0 8px 24px rgba(0,0,0,0.12));" loading="lazy" />
          </div>
          <div style="padding: var(--space-md); display: flex; flex-direction: column; flex-grow: 1;">
            <span style="font-family: var(--font-mono); font-size: var(--text-xs); text-transform: uppercase; letter-spacing: 0.1em; color: var(--accent-ochre); margin-bottom: var(--space-xs);">Build. Ship. Sell. Scale.</span>
            <h3 class="feature-title" style="margin-bottom: var(--space-sm);">Momentum Labs</h3>
            <p class="feature-text" style="font-size: var(--text-base); margin-bottom: var(--space-md); flex-grow: 1;">
              The innovation and execution arm of the Collective. This is where cohorts are run, live products are built, and developers are forged into commercial software engineers. 23+ active systems, all sold externally.
            </p>
            <div style="display: flex; gap: var(--space-sm); flex-wrap: wrap; margin-top: auto; border-top: 1px solid var(--border-subtle); padding-top: var(--space-sm);">
              <div style="display: flex; align-items: center; gap: var(--space-xs); font-family: var(--font-mono); font-size: var(--text-xs); text-transform: uppercase; border: 1px solid var(--border-subtle); padding: 4px 8px; border-radius: 4px;">
                <i data-lucide="smartphone" style="color: var(--accent-ochre); width: 14px; height: 14px;"></i><span>Mobile</span>
              </div>
              <div style="display: flex; align-items: center; gap: var(--space-xs); font-family: var(--font-mono); font-size: var(--text-xs); text-transform: uppercase; border: 1px solid var(--border-subtle); padding: 4px 8px; border-radius: 4px;">
                <i data-lucide="cloud" style="color: var(--accent-ochre); width: 14px; height: 14px;"></i><span>SaaS</span>
              </div>
              <div style="display: flex; align-items: center; gap: var(--space-xs); font-family: var(--font-mono); font-size: var(--text-xs); text-transform: uppercase; border: 1px solid var(--border-subtle); padding: 4px 8px; border-radius: 4px;">
                <i data-lucide="zap" style="color: var(--accent-ochre); width: 14px; height: 14px;"></i><span>AI</span>
              </div>
            </div>
          </div>
        </a>

        <!-- Momentum Foundation Pillar -->
        <article class="feature-card" data-reveal style="display: flex; flex-direction: column; padding: 0; overflow: hidden;">
          <div style="width: 100%; aspect-ratio: 1; background: var(--bg-alt); display: flex; align-items: center; justify-content: center; padding: var(--space-lg); border-bottom: 1px solid var(--border-subtle);">
            <img src="/assets/momentum-foundation.png" alt="Momentum Foundation" style="max-width: 80%; max-height: 80%; object-fit: contain; filter: drop-shadow(0 8px 24px rgba(0,0,0,0.12));" loading="lazy" />
          </div>
          <div style="padding: var(--space-md); display: flex; flex-direction: column; flex-grow: 1;">
            <span style="font-family: var(--font-mono); font-size: var(--text-xs); text-transform: uppercase; letter-spacing: 0.1em; color: var(--accent-ochre); margin-bottom: var(--space-xs);">Investments for Ventured Youths.</span>
            <h3 class="feature-title" style="margin-bottom: var(--space-sm);">Momentum Foundation</h3>
            <p class="feature-text" style="font-size: var(--text-base); margin-bottom: var(--space-md); flex-grow: 1;">
              The funding and empowerment pillar of our ecosystem. The Foundation is dedicated to providing grants, scholarships, and resources to young African talent, ensuring financial barriers don't stand in the way of innovation.
            </p>
            <div style="display: flex; gap: var(--space-sm); flex-wrap: wrap; margin-top: auto; border-top: 1px solid var(--border-subtle); padding-top: var(--space-sm);">
              <div style="display: flex; align-items: center; gap: var(--space-xs); font-family: var(--font-mono); font-size: var(--text-xs); text-transform: uppercase; border: 1px solid var(--border-subtle); padding: 4px 8px; border-radius: 4px;">
                <i data-lucide="graduation-cap" style="color: var(--accent-ochre); width: 14px; height: 14px;"></i><span>Scholarships</span>
              </div>
              <div style="display: flex; align-items: center; gap: var(--space-xs); font-family: var(--font-mono); font-size: var(--text-xs); text-transform: uppercase; border: 1px solid var(--border-subtle); padding: 4px 8px; border-radius: 4px;">
                <i data-lucide="heart" style="color: var(--accent-ochre); width: 14px; height: 14px;"></i><span>Grants</span>
              </div>
              <div style="display: flex; align-items: center; gap: var(--space-xs); font-family: var(--font-mono); font-size: var(--text-xs); text-transform: uppercase; border: 1px solid var(--border-subtle); padding: 4px 8px; border-radius: 4px;">
                <i data-lucide="users" style="color: var(--accent-ochre); width: 14px; height: 14px;"></i><span>Mentorship</span>
              </div>
            </div>
          </div>
        </article>
      </div>
    </div>
  </section>

  <!-- 5. TALENT PIPELINE -->
  <section class="section section-alt">
    <div class="container">
      <div class="section-header">
        <p class="eyebrow">Talent Pipeline</p>
        <h2 class="section-title">What You Leave With</h2>
        <p class="section-description">
          We produce developers who have shipped production software, understand
          product-market fit, have worked within agile teams, and have
          contributed to real revenue-generating systems.
        </p>
      </div>
      <div class="features-grid">
        <div class="feature-card" data-reveal>
          <div class="feature-icon">
            <i data-lucide="layers"></i>
          </div>
          <h3 class="feature-title">Absorbed Internally</h3>
          <p class="feature-text">
            Top-performing developers are absorbed into internal product teams,
            continuing to own and scale the same systems they built during the
            cohort.
          </p>
        </div>
        <div class="feature-card" data-reveal>
          <div class="feature-icon">
            <i data-lucide="building-2"></i>
          </div>
          <h3 class="feature-title">Deployed to Partners</h3>
          <p class="feature-text">
            Others are placed at partner companies, fully career-ready,
            commercially experienced, and proven on live, revenue-generating
            systems.
          </p>
        </div>
        <div class="feature-card" data-reveal>
          <div class="feature-icon">
            <i data-lucide="rocket"></i>
          </div>
          <h3 class="feature-title">Advanced Leadership</h3>
          <p class="feature-text">
            Select developers continue into product leadership roles, driving
            strategy, mentoring incoming cohorts, and expanding the Momentum
            ecosystem.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- 6. JOIN CTA -->
  <section class="section cta-section">
    <div class="kente-decoration"></div>
    <div class="container">
      <div class="cta-content">
        <h2 class="display-4xl mb-sm">Ready to Join the Lab?</h2>
        <p class="text-muted mb-md">
          Whether you're a developer ready to ship real software, a business
          looking for a live product team, or a partner looking to deploy our
          systems, there's a place for you in the Momentum ecosystem.
        </p>
        <div class="cta-buttons">
          <a href="/contact" class="btn btn-primary btn-lg">
            <i data-lucide="arrow-right"></i>
            <span>Join the Cohort</span>
          </a>
          <a href="/apps" class="btn btn-outline btn-lg">
            <i data-lucide="eye"></i>
            <span>See Our Products</span>
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
