---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="About | Momentum Collective"
  description="Learn about Momentum Collective, our vision, mission, and ecosystem — Momentum Labs and Momentum Foundation."
  barbaNamespace="about"
>
  <!-- 1. ABOUT HERO -->
  <section class="hero">
    <div class="container">
      <div class="hero-content">
        <p class="hero-eyebrow">About Us</p>
        <h1 class="hero-title" data-split>
          Empowering Africa's Digital Future
        </h1>
        <p class="hero-subtext">
          We are a dynamic ecosystem of young African developers, designers, and
          innovators united by a shared vision: to build solutions that
          transform communities and preserve our cultural heritage.
        </p>
        <div class="hero-buttons">
          <a href="/contact" class="btn btn-primary btn-lg">
            <span>Join Movement</span>
            <i data-lucide="arrow-right"></i>
          </a>
          <a href="/apps" class="btn btn-outline btn-lg">
            <span>Explore Work</span>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- 2. MISSION / VISION -->
  <section class="section section-alt">
    <div class="container">
      <div class="grid-2">
        <div data-reveal>
          <p class="eyebrow">Our Vision</p>
          <div class="card-icon mb-sm">
            <i data-lucide="eye"></i>
          </div>
          <h5>
            To empower communities, preserve culture, and build tools that
            address real-world needs. We champion underrepresented voices, honor
            our heritage, and nurture the next generation of African developers.
          </h5>
          <p class="eyebrow">"Our Ideas, Our Future."</p>
        </div>
        <div data-reveal>
          <p class="eyebrow">Our Mission</p>
          <div class="card-icon mb-sm">
            <i data-lucide="target"></i>
          </div>
          <h5>
            To provide hands-on experience, foster collaboration on meaningful
            projects, and create a seamless transition for young talent into the
            tech industry—all while delivering solutions that make a tangible
            impact across Africa.
          </h5>
        </div>
      </div>
    </div>
  </section>

  <!-- 3. ECOSYSTEM (Side-by-Side Editorial) -->
  <section class="section">
    <div class="container">
      <div class="section-header">
        <p class="eyebrow">Our Ecosystem</p>
        <h2 class="section-title">Two Interconnected Pillars</h2>
      </div>

      <div class="pillars-grid">
        <!-- Momentum Labs Pillar -->
        <a href="/labs" class="pillar" data-reveal>
          <div class="pillar-image-container">
            <img
              src="/assets/momentum-labs-upscaled.png"
              alt="Momentum Labs"
              class="pillar-image"
              loading="lazy"
            />
          </div>
          <div class="pillar-content">
            <div class="pillar-header">
              <span class="pillar-tagline">Our Ideas, Our Future.</span>
              <h3 class="pillar-title">Momentum Labs</h3>
            </div>
            <p class="pillar-description">
              The innovation arm of the Collective. This is where we design,
              build, and scale our cutting-edge digital products. From mobile
              apps to enterprise-level SaaS, Momentum Labs is where ideas become
              reality.
            </p>
            <div class="pillar-features">
              <div class="pillar-feature">
                <i data-lucide="smartphone"></i><span>Mobile Apps</span>
              </div>
              <div class="pillar-feature">
                <i data-lucide="cloud"></i><span>SaaS Solutions</span>
              </div>
              <div class="pillar-feature">
                <i data-lucide="code-2"></i><span>Open Source</span>
              </div>
            </div>
          </div>
        </a>

        <!-- Momentum Foundation Pillar -->
        <article class="pillar" data-reveal>
          <div class="pillar-image-container">
            <img
              src="/assets/momentum-foundation.png"
              alt="Momentum Foundation"
              class="pillar-image"
              loading="lazy"
            />
          </div>
          <div class="pillar-content">
            <div class="pillar-header">
              <span class="pillar-tagline"
                >Investments for Ventured Youths.</span
              >
              <h3 class="pillar-title">Momentum Foundation</h3>
            </div>
            <p class="pillar-description">
              The funding and empowerment pillar of our ecosystem. The
              Foundation is dedicated to providing grants, scholarships, and
              resources to young African talent, ensuring that financial
              barriers don't stand in the way of innovation.
            </p>
            <div class="pillar-features">
              <div class="pillar-feature">
                <i data-lucide="graduation-cap"></i><span>Scholarships</span>
              </div>
              <div class="pillar-feature">
                <i data-lucide="heart"></i><span>Grants</span>
              </div>
              <div class="pillar-feature">
                <i data-lucide="users"></i><span>Mentorship</span>
              </div>
            </div>
          </div>
        </article>
      </div>
    </div>
  </section>

  <!-- 4. JOIN CTA -->
  <section class="section cta-section">
    <div class="kente-decoration"></div>
    <div class="container">
      <div class="cta-content">
        <h2 class="display-4xl mb-sm">Ready to Join Our Movement?</h2>
        <p class="text-muted mb-md">
          Whether you're a developer, designer, entrepreneur, or simply
          passionate about Africa's digital future, there's a place for you in
          the Momentum Collective.
        </p>
        <div class="cta-buttons">
          <a href="/contact" class="btn btn-primary btn-lg">
            <i data-lucide="user-plus"></i>
            <span>Join Community</span>
          </a>
          <a href="/apps" class="btn btn-outline btn-lg">
            <i data-lucide="eye"></i>
            <span>See Our Work</span>
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
