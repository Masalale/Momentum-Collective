---
import BaseLayout from "../layouts/BaseLayout.astro";
import EnquiryForm from "../components/EnquiryForm.astro";
---

<BaseLayout
  title="Contact"
  description="Get in touch with Momentum Collective. Partner with us to build the future of Africa."
  barbaNamespace="contact"
>
  <!-- 1. CONTACT HERO -->
  <section class="hero hero-compact">
    <div class="container">
      <div class="hero-content">
        <p class="hero-eyebrow">Connect With Us</p>
        <h1 class="hero-title">Let's Scale African Innovation</h1>
        <p class="hero-subtext">
          Whether you have a product idea, want to partner, or just want to say
          hello, we're ready to listen.
        </p>
      </div>
    </div>
</section>

<!-- 2. CONTACT METHODS -->
  <section
    class="section"
    style="padding-top: var(--space-md); overflow: visible;"
  >
    <div class="container">
      <div class="card-grid-editorial cols-3">
        <!-- Email Entry -->
        <a
          href="mailto:management@momentumcollective.info"
          class="card-editorial"
                 >
          <div class="card-editorial-icon"><i data-lucide="mail"></i></div>
          <div class="card-editorial-tagline">Communication</div>
          <h3 class="card-editorial-title">Email Us</h3>
          <p class="card-editorial-description">
            For general inquiries, partnerships, and product proposals.
          </p>
          <div class="card-editorial-link">
            <span>management@momentumcollective.info</span><i
              data-lucide="arrow-right"></i>
          </div>
        </a>

        <!-- Phone Entry -->
        <a href="tel:+254110175110" class="card-editorial">
          <div class="card-editorial-icon"><i data-lucide="phone"></i></div>
          <div class="card-editorial-tagline">Quick Call</div>
          <h3 class="card-editorial-title">Phone</h3>
          <p class="card-editorial-description">
            Direct access to our Nairobi operations and support team.
          </p>
          <div class="card-editorial-link">
            <span>+254 110 175 110</span><i data-lucide="arrow-right"></i>
          </div>
        </a>

        <!-- Location Entry -->
        <div class="card-editorial">
          <div class="card-editorial-icon"><i data-lucide="map-pin"></i></div>
          <div class="card-editorial-tagline">Operations</div>
          <h3 class="card-editorial-title">Nairobi Office</h3>
          <p class="card-editorial-description">
            Heart of the innovation, serving the East African ecosystem.
          </p>
          <div class="card-editorial-link">
            <span>Nairobi, Kenya</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 3. ENQUIRY FORM -->
  <section class="section" id="contact-form-section">
    <div class="container">
      <div class="contact-form-grid">
        <!-- Left: heading context (sticky) -->
        <div class="contact-form-intro">
          <p class="eyebrow" style="margin-bottom: var(--space-xs);">Get In Touch</p>
          <h2 id="contact-form-heading" class="display-2xl">
            Start a Conversation
          </h2>
          <p class="text-muted" style="margin-top: var(--space-sm);">
            We read every message. Someone from the team will get back to you.
          </p>
        </div>
        <!-- Right: form -->
        <div class="contact-form-side">
          <EnquiryForm formId="contact-page-form" />
        </div>
      </div>
    </div>
  </section>

  <!-- 4. SOCIAL JOURNEY -->
  <section class="section section-alt">
    <div class="container">
      <div class="section-header">
        <p class="eyebrow">Stay Connected</p>
        <h2 class="display-3xl mb-xs">Follow Our Journey</h2>
        <p class="text-muted section-description">
          Witness our progress and the digital products we're building for the
          continent.
        </p>
      </div>

      <div class="grid-3" style="margin-top: var(--space-lg);">
        <a
          href="https://www.linkedin.com/company/momentumlabsclg/"
          target="_blank"
          rel="noopener noreferrer"
          class="card-editorial"
          style="text-align: center; align-items: center;"
                 >
          <div
            class="card-editorial-icon"
            style="margin-bottom: var(--space-sm);"
          >
            <i data-lucide="linkedin"></i>
          </div>
          <h3 class="card-editorial-title">LinkedIn</h3>
          <p class="card-editorial-description">
            Corporate updates and professional network.
          </p>
        </a>

        <a
          href="https://www.instagram.com/momentumcollectiveclg"
          target="_blank"
          rel="noopener noreferrer"
          class="card-editorial"
          style="text-align: center; align-items: center;"
                 >
          <div
            class="card-editorial-icon"
            style="margin-bottom: var(--space-sm);"
          >
            <i data-lucide="instagram"></i>
          </div>
          <h3 class="card-editorial-title">Instagram</h3>
          <p class="card-editorial-description">
            Behind the scenes and culture highlights.
          </p>
        </a>

        <a
          href="https://github.com/ivycommunity"
          target="_blank"
          rel="noopener noreferrer"
          class="card-editorial"
          style="text-align: center; align-items: center;"
                 >
          <div
            class="card-editorial-icon"
            style="margin-bottom: var(--space-sm);"
          >
            <i data-lucide="github"></i>
          </div>
          <h3 class="card-editorial-title">GitHub</h3>
          <p class="card-editorial-description">
            Open source contributions and experiments.
          </p>
        </a>
      </div>
    </div>
  </section>

</BaseLayout>
