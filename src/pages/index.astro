---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Building Africa's Digital Future | Momentum Collective" barbaNamespace="home">

  <!-- HERO: Clean and Simple -->
  <section class="hero">
    <div class="container">
      <div class="hero-content">
        <p class="hero-eyebrow">Pan-African Tech Collective</p>
        <h1 class="hero-title">
          Building Africa's Digital Future
        </h1>
        <p class="hero-subtext">
          We empower communities, preserve culture, and create scalable solutions that drive real change across the continent.
        </p>
        <div class="hero-buttons">
          <a href="/apps" class="btn btn-primary btn-lg">
            Explore Our Solutions
            <i data-lucide="arrow-right"></i>
          </a>
          <a href="/contact" class="btn btn-outline btn-lg">
            Partner With Us
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- STATS BAR -->
  <section class="stats-bar">
    <div class="container">
      <div class="stats-grid">
        <div class="stat-item">
          <span class="stat-number">8+</span>
          <span class="stat-label">Products Built</span>
        </div>
        <div class="stat-item">
          <span class="stat-number">4</span>
          <span class="stat-label">Countries Served</span>
        </div>
        <div class="stat-item">
          <span class="stat-number">12+</span>
          <span class="stat-label">Team Members</span>
        </div>
        <div class="stat-item">
          <span class="stat-number">100%</span>
          <span class="stat-label">Youth Led</span>
        </div>
      </div>
    </div>
  </section>

  <!-- WHAT WE DO -->
  <section class="section section-alt">
    <div class="container">
      <div class="section-header">
        <p class="eyebrow">What We Do</p>
        <h2 class="section-title">Solutions Built for Africa</h2>
        <p class="section-description">
          From mobile apps to enterprise platforms, we create technology that addresses real African challenges.
        </p>
      </div>

      <div class="features-grid">
        <div class="feature-card" data-reveal>
          <div class="feature-icon">
            <i data-lucide="smartphone"></i>
          </div>
          <h3 class="feature-title">Mobile Apps</h3>
          <p class="feature-text">Native and cross-platform applications designed for African connectivity and usage patterns.</p>
        </div>

        <div class="feature-card" data-reveal>
          <div class="feature-icon">
            <i data-lucide="cloud"></i>
          </div>
          <h3 class="feature-title">Cloud Solutions</h3>
          <p class="feature-text">Scalable SaaS platforms that help businesses grow without heavy infrastructure costs.</p>
        </div>

        <div class="feature-card" data-reveal>
          <div class="feature-icon">
            <i data-lucide="users"></i>
          </div>
          <h3 class="feature-title">Community Tools</h3>
          <p class="feature-text">Digital platforms that connect communities and preserve African cultural heritage.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- PRODUCTS SHOWCASE -->
  <section class="section">
    <div class="container">
      <div class="section-header">
        <p class="eyebrow">Our Products</p>
        <h2 class="section-title">Apps Making an Impact</h2>
      </div>

      <div class="products-grid">
        <div class="product-card" data-reveal>
          <div class="product-info">
            <h3 class="product-name">AfroNative</h3>
            <p class="product-tagline">Preserve & practice native languages</p>
            <p class="product-description">Learn African mother tongues through engaging lessons. Bridging generational language gaps.</p>
            <a href="#" class="product-link">Learn more <i data-lucide="arrow-right"></i></a>
          </div>
        </div>

        <div class="product-card" data-reveal>
          <div class="product-info">
            <h3 class="product-name">FreshMarikiti</h3>
            <p class="product-tagline">Digital marketplace for vendors</p>
            <p class="product-description">Empowers market vendors to sell and deliver goods digitally beyond physical stalls.</p>
            <a href="/fm-index" class="product-link">Learn more <i data-lucide="arrow-right"></i></a>
          </div>
        </div>

        <div class="product-card" data-reveal>
          <div class="product-info">
            <h3 class="product-name">Immuno</h3>
            <p class="product-tagline">Immunization tracking system</p>
            <p class="product-description">Helps hospitals track vaccination progress and send timely reminders to patients.</p>
            <a href="/immuno" class="product-link">Learn more <i data-lucide="arrow-right"></i></a>
          </div>
        </div>
      </div>

      <div class="section-cta">
        <a href="/apps" class="btn btn-outline btn-lg">View All Products</a>
      </div>
    </div>
  </section>

  <!-- CTA SECTION -->
  <section class="section section-alt">
    <div class="container">
      <div class="cta-box">
        <h2 class="cta-title">Ready to Build Together?</h2>
        <p class="cta-text">Whether you need a mobile app, SaaS platform, or custom solution, our team is ready to bring your vision to life.</p>
        <div class="cta-buttons">
          <a href="/contact" class="btn btn-primary btn-lg">
            Get In Touch
            <i data-lucide="arrow-right"></i>
          </a>
          <a href="/services" class="btn btn-outline btn-lg">Our Services</a>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<script>
  import { initScrollReveal } from '../scripts/scroll-init';
  document.addEventListener('DOMContentLoaded', () => {
    initScrollReveal();
  });
</script>
