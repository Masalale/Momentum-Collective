---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Build. Ship. Sell. Scale." barbaNamespace="home">
  <!-- HERO -->
  <section class="hero">
    <div class="container">
      <div class="hero-content">
        <p class="hero-eyebrow">Africa's Execution-First Product Lab</p>
        <h1 class="hero-title">Build. Ship. Sell. Scale.</h1>
        <p class="hero-subtext">
          Momentum Labs CLG is a 6-8 week intensive cohort where developers join
          live product teams, ship real software into the market, and transition
          from learners to product leaders.
        </p>
        <div class="hero-buttons">
          <a href="/apps" class="btn btn-primary btn-lg">
            <span>Explore Our Products</span>
            <i data-lucide="arrow-right"></i>
          </a>
          <a href="/contact?intent=developer#contact-form-section" class="btn btn-outline btn-lg">
            Join the Cohort
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- STATS BAR -->
  <section class="stats-bar">
    <div class="container">
      <div class="stats-grid">
        <div class="stat-item">
          <span class="stat-number">300+</span>
          <span class="stat-label">Developers Trained</span>
        </div>
        <div class="stat-item">
          <span class="stat-number">44+</span>
          <span class="stat-label">Live Products</span>
        </div>
        <div class="stat-item">
          <span class="stat-number">6-8</span>
          <span class="stat-label">Week Cohorts</span>
        </div>
        <div class="stat-item">
          <span class="stat-number">100%</span>
          <span class="stat-label">Production Ready</span>
        </div>
      </div>
    </div>
  </section>

  <!-- HOW WE OPERATE -->
  <section class="section section-alt">
    <div class="container">
      <div class="section-header">
        <p class="eyebrow">How We Operate</p>
        <h2 class="section-title">Not a Bootcamp. Not a Theory Lab.</h2>
        <p class="section-description">
          Momentum is a live product lab. Every line of code written here
          contributes to a real, revenue-generating system already in the
          market.
        </p>
      </div>

      <div class="features-grid">
        <div class="feature-card">
          <div class="feature-icon">
            <i data-lucide="users"></i>
          </div>
          <h3 class="feature-title">Join Live Product Teams</h3>
          <p class="feature-text">
            Developers are placed into active software teams working on
            client-facing systems deployed in the market, not simulated
            environments.
          </p>
        </div>

        <div class="feature-card">
          <div class="feature-icon">
            <i data-lucide="rocket"></i>
          </div>
          <h3 class="feature-title">Ship to Production</h3>
          <p class="feature-text">
            Features are built, tested, and deployed into live systems. Every
            commit touches real code serving real clients and institutions.
          </p>
        </div>

        <div class="feature-card">
          <div class="feature-icon">
            <i data-lucide="zap"></i>
          </div>
          <h3 class="feature-title">Get Absorbed or Deployed</h3>
          <p class="feature-text">
            Top-performing developers are absorbed into internal product teams
            or deployed to partner companies, fully career-ready and
            commercially experienced.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- PRODUCTS SHOWCASE -->
  <section class="section">
    <div class="container">
      <div class="section-header">
        <p class="eyebrow">Our Products</p>
        <h2 class="section-title">44+ Active Systems in the Market</h2>
      </div>

      <div class="products-grid">
        <div class="product-card">
          <div class="product-info">
            <h3 class="product-name">Immunization Tracker</h3>
            <p class="product-tagline">
              Digital health & vaccination management
            </p>
            <p class="product-description">
              Vaccination tracking, structured reporting, and clinic
              coordination, enabling better health outcomes across hospitals and
              clinics.
            </p>
          </div>
        </div>

        <div class="product-card">
          <div class="product-info">
            <h3 class="product-name">Digital Vendor Marketplace</h3>
            <p class="product-tagline">Digital marketplace for local vendors</p>
            <p class="product-description">
              Connecting local market vendors directly to consumers, extending
              reach far beyond physical market stalls.
            </p>
          </div>
        </div>

        <div class="product-card">
          <div class="product-info">
            <h3 class="product-name">Native Language Learning</h3>
            <p class="product-tagline">
              African language preservation platform
            </p>
            <p class="product-description">
              A language-learning platform dedicated to preserving and teaching
              African dialects, bridging generational gaps in cultural
              continuity.
            </p>
          </div>
        </div>
      </div>

      <div class="section-cta">
        <a href="/apps" class="btn btn-outline btn-lg">View All 44+ Products</a>
      </div>
    </div>
  </section>

  <!-- CTA SECTION -->
  <section class="section section-alt">
    <div class="container">
      <div class="cta-box">
        <h2 class="cta-title">Ready to Build Real Software?</h2>
        <p class="cta-text">
          Apply to the next cohort, partner with our product teams, or deploy
          our live systems into your organisation.
        </p>
        <div class="cta-buttons">
          <a href="/contact?intent=developer#contact-form-section" class="btn btn-primary btn-lg">
            <span>Join the Cohort</span>
            <i data-lucide="arrow-right"></i>
          </a>
          <a href="/services" class="btn btn-outline btn-lg">Partner With Us</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
