---
import BaseLayout from "../layouts/BaseLayout.astro";

const linkedInPosts = [
  {
    title: "Final Day for Hackathon Submissions",
    date: "2026-03-13",
    excerpt:
      "🚨 Final Day for Hackathon Submissions 🚨 Today marks the final deadline for submissions to the Africa Forward: Humanitarian in Tech Masterclass x Hackathon.",
    tag: "Event",
    url: "https://www.linkedin.com/feed/update/urn:li:activity:7438246421256028161/",
  },
  {
    title: "We’re Hiring: Unity Developers & 3D Animators",
    date: "2026-03-11",
    excerpt:
      "Momentum Labs is building the next generation of African-made digital experiences, and we’re looking for Unity Developers and 3D Animators to join us in building ManoeMano.",
    tag: "Hiring",
    url: "https://www.linkedin.com/feed/update/urn:li:activity:7437376845362290688/",
  },
  {
    title: "Thank You to Our Masterclass Speakers",
    date: "2026-03-06",
    excerpt:
      "A big thank you to the incredible speakers who joined us for the Africa Forward: Humanitarian in Tech Masterclass. Your insights on technology, innovation, and humanitarian impact created a powerful conversation.",
    tag: "Event Recap",
    url: "https://www.linkedin.com/feed/update/urn:li:activity:7435651086818095104/",
  },
  {
    title: "Africa Forward Masterclass & Hackathon is Live",
    date: "2026-03-06",
    excerpt:
      "Today is the day. Africa Forward – Humanitarian in Tech Masterclass & Hackathon is happening now.",
    tag: "Event",
    url: "https://www.linkedin.com/feed/update/urn:li:activity:7435545957838053376/",
  },
  {
    title: "Tomorrow We Convene: Africa Forward",
    date: "2026-03-05",
    excerpt:
      "Tomorrow, we convene. Africa Forward – Humanitarian in Tech Masterclass & Hackathon (2nd Edition) goes live.",
    tag: "Event Announcement",
    url: "https://www.linkedin.com/feed/update/urn:li:activity:7435202776504188928/",
  },
];
---

<BaseLayout
  title="Newsletter"
  description="Stay up to date with Momentum Collective. Follow product launches, developer milestones, and innovation from Africa's execution-first product lab."
  barbaNamespace="newsletter"
>
  <!-- 1. HERO -->
  <section class="hero hero-compact">
    <div class="container">
      <div class="hero-content">
        <p class="hero-eyebrow">Stay Connected</p>
        <h1 class="hero-title">The Momentum Dispatch</h1>
        <p class="hero-subtext">
          Product launches, developer milestones, market wins, and insights from
          inside Africa's execution-first product lab. Delivered when it
          matters.
        </p>
      </div>
    </div>
  </section>

  <!-- 2. SUBSCRIBE -->
  <section class="section" style="padding-top: var(--space-md);">
    <div class="container">
      <div class="cta-box newsletter-subscribe-box">
        <p class="eyebrow">Subscribe</p>
        <h2 class="cta-title" style="margin-bottom: var(--space-sm);">
          Join the Inner Circle
        </h2>
        <p
          class="text-muted"
          style="margin-bottom: var(--space-md); font-size: var(--text-base);"
        >
          No noise. Just meaningful updates on what we're building, who we're
          deploying, and where the ecosystem is heading.
        </p>
        <form
          id="newsletter-form"
          class="newsletter-form"
          style="display: flex; gap: var(--space-sm); flex-wrap: wrap; justify-content: center;"
        >
          <input
            type="email"
            id="newsletter-email"
            class="newsletter-input"
            placeholder="your@email.com"
          />
          <button type="submit" class="btn btn-primary btn-lg">
            <span>Subscribe</span>
            <i data-lucide="arrow-right"></i>
          </button>
        </form>
        <p
          id="newsletter-status"
          style="font-family: var(--font-mono); font-size: var(--text-xs); color: var(--accent-ochre); text-transform: uppercase; letter-spacing: 0.1em; margin-top: var(--space-sm); display: none;"
        >
        </p>
        <p
          style="font-family: var(--font-mono); font-size: var(--text-xs); color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.1em; margin-top: var(--space-sm);"
        >
          No spam. Unsubscribe any time.
        </p>

        <script>
          const form = document.getElementById(
            "newsletter-form",
          ) as HTMLFormElement;
          const emailInput = document.getElementById(
            "newsletter-email",
          ) as HTMLInputElement;
          const status = document.getElementById(
            "newsletter-status",
          ) as HTMLElement;

          form?.addEventListener("submit", (e) => {
            e.preventDefault();
            const prefilling = emailInput?.value
              ? `?subject=${encodeURIComponent("Newsletter Interest")}&body=${encodeURIComponent(`Hi Momentum, please add ${emailInput.value} to the newsletter dispatch list.`)}`
              : "";
            status.textContent = "Newsletter coming soon. Please use our contact form for updates.";
            const link = document.createElement("a");
            link.href = `/contact${prefilling}#contact-form-section`;
            link.textContent = " Open contact form";
            link.style.textDecoration = "underline";
            status.appendChild(link);
            status.style.display = "block";
          });
</script>
      </div>
    </div>
  </section>

  <!-- 3. WHAT TO EXPECT -->
  <section class="section section-alt">
    <div class="container">
      <div class="section-header">
        <p class="eyebrow">What You'll Get</p>
        <h2 class="section-title">Inside Every Issue</h2>
      </div>

      <div class="features-grid">
        <div class="feature-card">
          <div class="feature-icon">
            <i data-lucide="rocket"></i>
          </div>
          <h3 class="feature-title">Product Launches</h3>
          <p class="feature-text">
            First-look announcements every time a new Momentum system ships to
            market.
          </p>
        </div>

        <div class="feature-card">
          <div class="feature-icon">
            <i data-lucide="users"></i>
          </div>
          <h3 class="feature-title">Cohort Updates</h3>
          <p class="feature-text">
            Stories from active cohorts, developer milestones, and team
            highlights.
          </p>
        </div>

        <div class="feature-card">
          <div class="feature-icon">
            <i data-lucide="bar-chart-2"></i>
          </div>
          <h3 class="feature-title">Market Insights</h3>
          <p class="feature-text">
            Observations on tech adoption, African market trends, and what we're
            learning on the ground.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- 4. LINKEDIN UPDATES -->
  <section class="section">
    <div class="container">
      <!-- 3. LATEST UPDATES (LinkedIn Feed) -->
      <div
        id="updates"
        class="section-header"
        style="margin-top: var(--space-xl);"
      >
        <p class="eyebrow">The Network</p>
        <h2 class="section-title">Latest Updates</h2>
        <p class="section-description">
          Dispatches, milestones, and partner announcements from the Momentum
          ecosystem.
        </p>
      </div>

      <div class="publication-container">
        {
          linkedInPosts.map((post) => (
            <a
              href={post.url}
              target="_blank"
              rel="noopener noreferrer"
              class="article-row"
                         >
              <div class="article-meta">
                <time class="article-date" datetime={post.date} data-reltime>
                  {new Date(post.date).toLocaleDateString("en-GB", {
                    day: "numeric",
                    month: "short",
                    year: "numeric",
                  })}
                </time>
                <span class="article-tag">{post.tag}</span>
              </div>

              <div class="article-main">
                <h3 class="article-title">{post.title}</h3>
                <p class="article-excerpt">{post.excerpt}</p>
              </div>

              <div class="article-action">
                <span class="article-action-label">Read</span>
                <i data-lucide="arrow-up-right" />
              </div>
            </a>
          ))
        }
      </div>

      <div class="newsletter-linkedin-cta">
        <a
          href="https://www.linkedin.com/company/momentumlabsclg/"
          target="_blank"
          rel="noopener noreferrer"
          class="btn btn-primary btn-lg"
        >
          <span>Follow Us on LinkedIn</span>
          <i data-lucide="external-link"></i>
        </a>
      </div>
    </div>
  </section>

  <!-- 5. CTA -->
  <section class="section cta-section">
    <div class="kente-decoration"></div>
    <div class="container">
      <div class="cta-content">
        <h2 class="display-3xl mb-xs">Build. Ship. Sell. Scale.</h2>
        <p class="text-muted mb-md" style="font-size: var(--text-base);">
          Follow the journey as we build Africa's most execution-focused product
          lab.
        </p>
        <div class="cta-buttons">
          <a href="/contact" class="btn btn-primary btn-lg">
            <span>Partner With Us</span>
            <i data-lucide="arrow-right"></i>
          </a>
          <a href="/apps" class="btn btn-outline btn-lg">
            <span>See Our Products</span>
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
